<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <sys:String x:Key="App.Title">DriverUpdater</sys:String>
    <sys:String x:Key="App.Version">v0.1.27</sys:String>
    <sys:String x:Key="App.Admin">Administrator</sys:String>
    <sys:String x:Key="App.NotElevated">Not elevated</sys:String>

    <sys:String x:Key="Toolbar.Scan">Scan now</sys:String>
    <sys:String x:Key="Toolbar.ScanWithAi">Scan with AI</sys:String>
    <sys:String x:Key="Toolbar.Cancel">Cancel</sys:String>
    <sys:String x:Key="Toolbar.UpdateAll">Update all</sys:String>
    <sys:String x:Key="Toolbar.UpdateSelected">Update selected</sys:String>
    <sys:String x:Key="Toolbar.OpenVendorChecks">Open vendor checks</sys:String>
    <sys:String x:Key="Toolbar.History">History</sys:String>
    <sys:String x:Key="Toolbar.Logs">Logs</sys:String>
    <sys:String x:Key="Toolbar.Settings">Settings</sys:String>
    <sys:String x:Key="Toolbar.UpdateApp">Update app</sys:String>
    <sys:String x:Key="Update.AvailableTitle">Update available</sys:String>
    <sys:String x:Key="Update.AvailableMessage">A new version ({0}) is available. Update now? The app will restart to finish installing.</sys:String>
    <sys:String x:Key="Reboot.RequiredTitle">Restart required</sys:String>
    <sys:String x:Key="Reboot.RequiredMessage">{0} driver update(s) need a restart to finish. Restart the computer now?</sys:String>
    <sys:String x:Key="Reboot.ShutdownComment">DriverUpdater is restarting to finish driver installation.</sys:String>
    <sys:String x:Key="AiQuota.Title">AI quota reached</sys:String>
    <sys:String x:Key="AiQuota.DailyMessage">The Gemini AI request and token quota has been used up. Daily quotas reset at midnight Pacific time. AI should be available again around {0}. Driver scanning and updates can continue without AI.</sys:String>
    <sys:String x:Key="AiQuota.TemporaryMessage">Gemini is temporarily limiting AI requests because too many requests or tokens were used in a short time. AI should be available again around {0}. Driver scanning and updates can continue without AI.</sys:String>
    <sys:String x:Key="AiScanWarning.Title">Scan with AI</sys:String>
    <sys:String x:Key="AiScanWarning.Heading">Gemini request usage</sys:String>
    <sys:String x:Key="AiScanWarning.UsageKnown">This scan plans {0} Gemini request(s). DriverUpdater has sent {1} request(s) today for {4}. Projected local usage after the scan: {2} of {3} daily requests.</sys:String>
    <sys:String x:Key="AiScanWarning.UsageUnknown">This scan plans {0} Gemini request(s). DriverUpdater has sent {1} request(s) today for {2}. Enter the daily RPD limit shown in Google AI Studio to see usage out of your quota.</sys:String>
    <sys:String x:Key="AiScanWarning.QuotaExplanation">Google applies quotas per project and model. DriverUpdater counts requests sent by this app, but only AI Studio knows your active quota and usage from other apps. Retries or fallback attempts can add requests.</sys:String>
    <sys:String x:Key="AiScanWarning.DailyLimitLabel">Daily request limit</sys:String>
    <sys:String x:Key="AiScanWarning.DailyLimitHint">Enter the total RPD across configured projects. Count keys from the same project only once. Leave empty if unknown.</sys:String>
    <sys:String x:Key="AiScanWarning.OpenLimits">Open AI Studio</sys:String>
    <sys:String x:Key="AiScanWarning.DoNotShowAgain">Do not show this warning again</sys:String>
    <sys:String x:Key="AiScanWarning.Cancel">Use regular scan</sys:String>
    <sys:String x:Key="AiScanWarning.Start">Start AI scan</sys:String>

    <sys:String x:Key="Filter.Search">Search device, provider, hardware ID...</sys:String>
    <sys:String x:Key="Filter.AllCategories">All categories</sys:String>

    <sys:String x:Key="Grid.Status">Status</sys:String>
    <sys:String x:Key="Grid.Device">Device</sys:String>
    <sys:String x:Key="Grid.Category">Category</sys:String>
    <sys:String x:Key="Grid.Version">Version</sys:String>
    <sys:String x:Key="Grid.Date">Date</sys:String>
    <sys:String x:Key="Grid.Available">Available</sys:String>
    <sys:String x:Key="Grid.AvailableDate">Available date</sys:String>
    <sys:String x:Key="Grid.Source">Source</sys:String>
    <sys:String x:Key="Grid.Progress">Progress</sys:String>
    <sys:String x:Key="Grid.Update">Update</sys:String>
    <sys:String x:Key="Grid.Ai">AI check</sys:String>
    <sys:String x:Key="Grid.Provider">Provider</sys:String>
    <sys:String x:Key="Grid.DriverVersion">Driver version</sys:String>

    <sys:String x:Key="Confirm.Title">Confirm driver update</sys:String>
    <sys:String x:Key="Confirm.Current">Current</sys:String>
    <sys:String x:Key="Confirm.Available">Available</sys:String>
    <sys:String x:Key="Confirm.Source">Source</sys:String>
    <sys:String x:Key="Confirm.CreateRestorePoint">Create system restore point before installing</sys:String>
    <sys:String x:Key="Confirm.BackupDriver">Back up current driver before installing</sys:String>
    <sys:String x:Key="Confirm.RiskHeader">Caution:</sys:String>
    <sys:String x:Key="Confirm.RiskBody">Storage and display drivers can prevent Windows from booting if they fail. The restore point and backup mitigate but do not eliminate this risk.</sys:String>
    <sys:String x:Key="Confirm.ImpactHeader">Before you continue</sys:String>
    <sys:String x:Key="Confirm.RestartRequired">A computer restart is required after this update. Save your work before proceeding.</sys:String>
    <sys:String x:Key="Confirm.RestartPossible">This update may require a computer restart. Save your work before proceeding.</sys:String>
    <sys:String x:Key="Confirm.Impact.Display">The screen may flicker or go black temporarily. Games, video, and graphics apps may stop or close.</sys:String>
    <sys:String x:Key="Confirm.Impact.Network">The network connection, VPN, calls, and active downloads may be interrupted temporarily.</sys:String>
    <sys:String x:Key="Confirm.Impact.AudioCamera">Audio, camera, calls, recordings, and apps using this device may stop temporarily.</sys:String>
    <sys:String x:Key="Confirm.Impact.Input">The keyboard, mouse, USB, or Bluetooth device may disconnect temporarily.</sys:String>
    <sys:String x:Key="Confirm.Impact.StorageSystem">System services or active work may be interrupted. Close important apps and save open files first.</sys:String>
    <sys:String x:Key="Confirm.Impact.Printer">Printing and active print jobs may be interrupted temporarily.</sys:String>
    <sys:String x:Key="Confirm.Impact.Generic">The device and apps using it may be unavailable temporarily during installation.</sys:String>
    <sys:String x:Key="Confirm.Impact.VendorInstaller">The vendor installer may close related apps or ask for additional confirmation.</sys:String>
    <sys:String x:Key="Confirm.CancelButton">Cancel</sys:String>
    <sys:String x:Key="Confirm.ProceedButton">Proceed</sys:String>

    <sys:String x:Key="Settings.Title">DriverUpdater - Settings</sys:String>
    <sys:String x:Key="Settings.Save">Save</sys:String>
    <sys:String x:Key="Settings.Close">Close</sys:String>
    <sys:String x:Key="Settings.Tab.Sources">Sources</sys:String>
    <sys:String x:Key="Settings.Tab.Safety">Safety</sys:String>
    <sys:String x:Key="Settings.Tab.Schedule">Schedule</sys:String>
    <sys:String x:Key="Settings.Tab.Language">Language</sys:String>
    <sys:String x:Key="Settings.Tab.Ai">AI</sys:String>
    <sys:String x:Key="Settings.Tab.About">About</sys:String>
    <sys:String x:Key="Settings.Language.Label">Language</sys:String>
    <sys:String x:Key="Settings.Language.Hint">Restart the app to fully apply the language change in every window.</sys:String>
    <sys:String x:Key="Settings.Ai.Intro">Scan now runs without AI. Scan with AI adds verification that found updates are genuinely newer than what is installed and searches for newer official drivers. AI is optional, and regular scans never use AI requests.</sys:String>
    <sys:String x:Key="Settings.Ai.Provider">Provider</sys:String>
    <sys:String x:Key="Settings.Ai.ResponseLanguage">AI response language</sys:String>
    <sys:String x:Key="Settings.Ai.ResponseLanguage.English">English</sys:String>
    <sys:String x:Key="Settings.Ai.ResponseLanguage.Hebrew">Hebrew</sys:String>
    <sys:String x:Key="Settings.Ai.ResponseLanguageHint">Ask AI and driver verification responses will be written in this language.</sys:String>
    <sys:String x:Key="Settings.Ai.ApiKey">API key</sys:String>
    <sys:String x:Key="Settings.Ai.ApiKeys">Gemini API keys</sys:String>
    <sys:String x:Key="Settings.Ai.GeminiDescription">Used only when you choose Scan with AI or Ask AI.</sys:String>
    <sys:String x:Key="Settings.Ai.OpenApiKeys">Create or manage API keys</sys:String>
    <sys:String x:Key="Settings.Ai.AddKey">Add another API key</sys:String>
    <sys:String x:Key="Settings.Ai.RemoveKey">Remove</sys:String>
    <sys:String x:Key="Settings.Ai.FallbackExplanation">When a key's project reaches its quota, DriverUpdater automatically tries the next key. For useful fallback, use keys from different Google Cloud projects. Keys from the same project share quota.</sys:String>
    <sys:String x:Key="Settings.Ai.Model">Model</sys:String>
    <sys:String x:Key="Settings.Ai.DailyRequestLimit">Daily RPD limit</sys:String>
    <sys:String x:Key="Settings.Ai.DailyRequestLimitHint">Enter the total RPD available across the configured projects. Count a shared project only once. Use 0 when unknown.</sys:String>
    <sys:String x:Key="Settings.Ai.ShowScanWarning">Show the Gemini request usage warning before AI scans</sys:String>
    <sys:String x:Key="Settings.Ai.WebSearch">Use live web search to check for the latest version and reported issues</sys:String>
    <sys:String x:Key="Settings.Ai.OllamaUrl">Base URL</sys:String>
    <sys:String x:Key="Settings.Ai.KeyWarning">Gemini API keys are stored in plain text in settings.json on this computer. Only enable this on a machine you trust.</sys:String>
    <sys:String x:Key="Settings.Ai.GeminiGuideHeader">How to set up Gemini (free)</sys:String>
    <sys:String x:Key="Settings.Ai.GeminiGuideBody">1. Open Google AI Studio (link below) and sign in.&#x0a;2. Click "Create API key" and copy the key.&#x0a;3. Paste it into the first API key field above.&#x0a;4. For fallback, click "Add another API key" and use a key from a different Google Cloud project. Keys from the same project share quota.&#x0a;5. Keep the default model or type another Gemini model name.&#x0a;6. Leave web search on so the model can check the newest version and known issues.&#x0a;&#x0a;When one project reaches its quota, DriverUpdater tries the next available key. Keys are sent only to Google.</sys:String>
    <sys:String x:Key="Settings.Ai.OllamaGuideHeader">How to set up Ollama (local, no key)</sys:String>
    <sys:String x:Key="Settings.Ai.OllamaGuideBody">1. Download and install Ollama from the link below.&#x0a;2. Open a terminal and run:  ollama pull llama3.1&#x0a;3. Make sure Ollama is running. It listens on http://localhost:11434 by default.&#x0a;4. Keep the default base URL, or change it if Ollama runs elsewhere.&#x0a;5. Type the model you pulled (for example llama3.1) in the model box above.&#x0a;&#x0a;Ollama runs entirely on your PC - no API key and no internet are needed.</sys:String>
    <sys:String x:Key="Settings.OpenGuide">Open the setup guide</sys:String>
    <sys:String x:Key="Settings.ShowGuideOnStartup">Open the guide whenever DriverUpdater starts</sys:String>

    <sys:String x:Key="History.Title">DriverUpdater - History</sys:String>
    <sys:String x:Key="History.Heading">Update history</sys:String>
    <sys:String x:Key="History.Refresh">Refresh</sys:String>
    <sys:String x:Key="History.Rollback">Rollback</sys:String>
</ResourceDictionary>
