<Application x:Class="DriverUpdater.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             xmlns:ui="http://schemas.modernwpf.com/2019">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemeResources />
                <ui:XamlControlsResources />
                <ResourceDictionary Source="/DriverUpdater;component/Resources/Strings.en.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

            <!-- Purple-to-blue gradient used for the AI sparkle (chat) buttons. -->
            <LinearGradientBrush x:Key="AiSparkleBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#C084FC" Offset="0" />
                <GradientStop Color="#8B5CF6" Offset="0.45" />
                <GradientStop Color="#3B82F6" Offset="1" />
            </LinearGradientBrush>
        </ResourceDictionary>
    </Application.Resources>
</Application>
