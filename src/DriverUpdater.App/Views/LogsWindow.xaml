<Window x:Class="DriverUpdater.App.Views.LogsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:vm="clr-namespace:DriverUpdater.App.ViewModels"
        xmlns:logging="clr-namespace:DriverUpdater.App.Logging"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:LogsViewModel}"
        Title="DriverUpdater - Logs"
        Width="1100" Height="650"
        MinWidth="820" MinHeight="400"
        ui:WindowHelper.UseModernWindowStyle="True"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="20,12"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Live logs" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />

                <ToggleButton x:Name="PauseToggle"
                              Margin="20,0,0,0"
                              Padding="14,4"
                              Content="Pause"
                              IsChecked="{Binding IsPaused, Mode=TwoWay}">
                    <ToggleButton.Style>
                        <Style TargetType="ToggleButton" BasedOn="{StaticResource {x:Type ToggleButton}}">
                            <Style.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter Property="Content" Value="Resume" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ToggleButton.Style>
                </ToggleButton>

                <Button Margin="8,0,0,0"
                        Padding="14,4"
                        Content="Copy all"
                        Command="{Binding CopyAllCommand}" />

                <Button Margin="8,0,0,0"
                        Padding="14,4"
                        Content="Copy selected"
                        Command="{Binding CopySelectionCommand}"
                        CommandParameter="{Binding SelectedItems, ElementName=LogsGrid}" />

                <Button Margin="8,0,0,0"
                        Padding="14,4"
                        Content="Clear"
                        Command="{Binding ClearCommand}" />

                <Button Margin="8,0,0,0"
                        Padding="14,4"
                        Content="Open log folder"
                        Command="{Binding OpenLogFolderCommand}" />

                <TextBlock Margin="24,0,8,0" VerticalAlignment="Center" Text="Level:" />
                <ComboBox MinWidth="120"
                          ItemsSource="{Binding AvailableLevels}"
                          SelectedItem="{Binding SelectedLevel, Mode=TwoWay}" />

                <CheckBox Margin="20,0,0,0"
                          VerticalAlignment="Center"
                          Content="Auto-scroll"
                          IsChecked="{Binding AutoScroll, Mode=TwoWay}" />
            </StackPanel>
        </Border>

        <DataGrid x:Name="LogsGrid"
                  Grid.Row="1"
                  Margin="20,12,20,8"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeRows="False"
                  GridLinesVisibility="None"
                  HeadersVisibility="Column"
                  IsReadOnly="True"
                  SelectionMode="Extended"
                  RowHeight="26"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  FontFamily="Consolas, Cascadia Mono, Courier New, monospace"
                  FontSize="12"
                  ItemsSource="{Binding Entries}">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Level}" Value="Warning">
                            <Setter Property="Foreground" Value="#D18B00" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Level}" Value="Error">
                            <Setter Property="Foreground" Value="#D13438" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Level}" Value="Fatal">
                            <Setter Property="Foreground" Value="#A4262C" />
                            <Setter Property="FontWeight" Value="Bold" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Level}" Value="Debug">
                            <Setter Property="Opacity" Value="0.7" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Level}" Value="Verbose">
                            <Setter Property="Opacity" Value="0.55" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Time"
                                    Binding="{Binding Timestamp, StringFormat=HH:mm:ss.fff}"
                                    Width="100" />
                <DataGridTextColumn Header="Level"
                                    Binding="{Binding Level}"
                                    Width="90" />
                <DataGridTextColumn Header="Category"
                                    Binding="{Binding Category}"
                                    Width="180" />
                <DataGridTextColumn Header="Message"
                                    Binding="{Binding Message}"
                                    Width="*" />
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="2"
                Padding="20,8"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
            <TextBlock Text="{Binding StatusText}" Opacity="0.85" FontSize="12" />
        </Border>
    </Grid>
</Window>
