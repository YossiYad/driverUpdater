<Window x:Class="DriverUpdater.App.Views.LogsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:vm="clr-namespace:DriverUpdater.App.ViewModels"
        xmlns:logging="clr-namespace:DriverUpdater.App.Logging"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:LogsViewModel}"
        Title="DriverUpdater - Logs"
        Icon="pack://application:,,,/Assets/app.ico"
        Width="1100" Height="650"
        MinWidth="820" MinHeight="400"
        ui:WindowHelper.UseModernWindowStyle="True"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="20,12"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
            <DockPanel LastChildFill="True">
                <!-- AI chat toggle: two sparkles that open/close the Ask-AI panel. -->
                <ToggleButton DockPanel.Dock="Right"
                              Margin="12,0,0,0"
                              Padding="10,4"
                              VerticalAlignment="Center"
                              IsChecked="{Binding IsChatPanelVisible, Mode=TwoWay}"
                              Visibility="{Binding IsAiAvailable, Converter={StaticResource BooleanToVisibilityConverter}}"
                              ToolTip="Show or hide the Ask-AI chat panel">
                    <TextBlock Text="&#x2726;&#x2727;"
                               FontSize="16"
                               FontWeight="SemiBold" />
                </ToggleButton>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Live logs" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />

                <ToggleButton x:Name="PauseToggle"
                              Margin="20,0,0,0"
                              Padding="14,4"
                              Content="Pause"
                              IsChecked="{Binding IsPaused, Mode=TwoWay}">
                    <ToggleButton.Style>
                        <Style TargetType="ToggleButton" BasedOn="{StaticResource {x:Type ToggleButton}}">
                            <Style.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter Property="Content" Value="Resume" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ToggleButton.Style>
                </ToggleButton>

                <Button Margin="8,0,0,0"
                        Padding="14,4"
                        Content="Copy all"
                        Command="{Binding CopyAllCommand}" />

                <Button Margin="8,0,0,0"
                        Padding="14,4"
                        Content="Copy selected"
                        Command="{Binding CopySelectionCommand}"
                        CommandParameter="{Binding SelectedItems, ElementName=LogsGrid}" />

                <Button Margin="8,0,0,0"
                        Padding="14,4"
                        Content="Clear"
                        Command="{Binding ClearCommand}" />

                <Button Margin="8,0,0,0"
                        Padding="14,4"
                        Content="Open log folder"
                        Command="{Binding OpenLogFolderCommand}" />

                <Button Margin="8,0,0,0"
                        Padding="14,4"
                        Content="AI summary"
                        Command="{Binding SummarizeWithAiCommand}"
                        Style="{DynamicResource AccentButtonStyle}"
                        ToolTip="Summarize the logs with AI and copy the result to the clipboard so you can share it." />

                <ProgressBar Width="90"
                             Height="6"
                             Margin="8,0,0,0"
                             VerticalAlignment="Center"
                             IsIndeterminate="True"
                             Visibility="{Binding IsSummarizing, Converter={StaticResource BooleanToVisibilityConverter}}" />

                <TextBlock Margin="24,0,8,0" VerticalAlignment="Center" Text="Level:" />
                <ComboBox MinWidth="120"
                          ItemsSource="{Binding AvailableLevels}"
                          SelectedItem="{Binding SelectedLevel, Mode=TwoWay}" />

                <CheckBox Margin="20,0,0,0"
                          VerticalAlignment="Center"
                          Content="Auto-scroll"
                          IsChecked="{Binding AutoScroll, Mode=TwoWay}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

        <DataGrid x:Name="LogsGrid"
                  Grid.Column="0"
                  Margin="20,12,20,8"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeRows="False"
                  GridLinesVisibility="None"
                  HeadersVisibility="Column"
                  IsReadOnly="True"
                  SelectionMode="Extended"
                  RowHeight="26"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  FontFamily="Consolas, Cascadia Mono, Courier New, monospace"
                  FontSize="12"
                  ItemsSource="{Binding Entries}">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Level}" Value="Warning">
                            <Setter Property="Foreground" Value="#D18B00" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Level}" Value="Error">
                            <Setter Property="Foreground" Value="#D13438" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Level}" Value="Fatal">
                            <Setter Property="Foreground" Value="#A4262C" />
                            <Setter Property="FontWeight" Value="Bold" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Level}" Value="Debug">
                            <Setter Property="Opacity" Value="0.7" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Level}" Value="Verbose">
                            <Setter Property="Opacity" Value="0.55" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Time"
                                    Binding="{Binding Timestamp, StringFormat=HH:mm:ss.fff}"
                                    Width="100" />
                <DataGridTextColumn Header="Level"
                                    Binding="{Binding Level}"
                                    Width="90" />
                <DataGridTextColumn Header="Category"
                                    Binding="{Binding Category}"
                                    Width="180" />
                <DataGridTextColumn Header="Message"
                                    Binding="{Binding Message}"
                                    Width="*" />
            </DataGrid.Columns>
        </DataGrid>

            <GridSplitter Grid.Column="1"
                          Width="4"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          ResizeBehavior="PreviousAndNext"
                          Background="Transparent"
                          Visibility="{Binding IsChatPanelShown, Converter={StaticResource BooleanToVisibilityConverter}}" />

            <Border Grid.Column="2"
                    Width="360"
                    Margin="0,12,20,8"
                    Padding="12,10"
                    CornerRadius="4"
                    Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                    BorderBrush="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                    BorderThickness="1"
                    Visibility="{Binding IsChatPanelShown, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Ask AI about these logs" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <ProgressBar Width="60"
                                     Height="4"
                                     Margin="10,0,0,0"
                                     VerticalAlignment="Center"
                                     IsIndeterminate="True"
                                     Visibility="{Binding IsChatting, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <Button Margin="10,0,0,0"
                                Padding="8,2"
                                Content="Clear"
                                FontSize="11"
                                Command="{Binding ClearChatCommand}"
                                Visibility="{Binding HasChat, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>

                    <Border Grid.Row="1"
                            Visibility="{Binding HasNoChat, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="Ask a question about what happened in this session — errors, why a driver failed, what was updated, and so on. The AI answers from the current session logs."
                                   TextWrapping="Wrap"
                                   Opacity="0.7"
                                   FontSize="12"
                                   VerticalAlignment="Top" />
                    </Border>

                    <ScrollViewer Grid.Row="1"
                                  x:Name="ChatScroll"
                                  VerticalScrollBarVisibility="Auto"
                                  Visibility="{Binding HasChat, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ItemsControl ItemsSource="{Binding ChatMessages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8"
                                            Padding="10,7"
                                            CornerRadius="6">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumBrush}" />
                                                <Setter Property="HorizontalAlignment" Value="Left" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource SystemControlHighlightAccentBrush}" />
                                                        <Setter Property="HorizontalAlignment" Value="Right" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="{Binding RoleLabel}"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Opacity="0.7"
                                                       Margin="0,0,0,2" />
                                            <TextBlock Text="{Binding Text}"
                                                       TextWrapping="Wrap"
                                                       FontSize="12"
                                                       MaxWidth="300" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Grid Grid.Row="2" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 x:Name="ChatInputBox"
                                 Text="{Binding ChatInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 ui:ControlHelper.PlaceholderText="Ask about the logs..."
                                 TextWrapping="Wrap"
                                 AcceptsReturn="False"
                                 MaxLength="1000"
                                 VerticalContentAlignment="Center">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding SendChatCommand}" />
                            </TextBox.InputBindings>
                        </TextBox>
                        <Button Grid.Column="1"
                                Margin="8,0,0,0"
                                Padding="14,4"
                                Content="Send"
                                Command="{Binding SendChatCommand}"
                                Style="{DynamicResource AccentButtonStyle}" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Margin="20,0,20,8"
                Padding="12,10"
                CornerRadius="4"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                BorderBrush="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                BorderThickness="1"
                Visibility="{Binding HasAiSummary, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="AI log summary" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Button Margin="12,0,0,0"
                            Padding="10,2"
                            Content="Copy summary"
                            Command="{Binding CopyAiSummaryCommand}" />
                </StackPanel>
                <TextBox Grid.Row="1"
                         Text="{Binding AiSummary, Mode=OneWay}"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         MaxHeight="200"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas, Cascadia Mono, Courier New, monospace"
                         FontSize="12" />
            </Grid>
        </Border>

        <Border Grid.Row="3"
                Padding="20,8"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
            <TextBlock Text="{Binding StatusText}" Opacity="0.85" FontSize="12" />
        </Border>
    </Grid>
</Window>
