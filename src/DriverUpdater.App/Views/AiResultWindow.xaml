<ui:FluentWindow x:Class="DriverUpdater.App.Views.AiResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:DriverUpdater.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:AiResultViewModel}"
        Title="DriverUpdater - AI response"
        Icon="pack://application:,,,/Assets/app.ico"
        Width="760" Height="620"
        MinWidth="620" MinHeight="480"
        WindowStartupLocation="CenterOwner"
        >
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="20,14"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
            <StackPanel>
                <TextBlock Text="{Binding DeviceName}"
                           FontSize="20"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Margin="0,4,0,0"
                           Opacity="0.7"
                           Text="{Binding Recommendation}" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1"
                      Padding="20,16"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="AI recommendation"
                           FontSize="16"
                           FontWeight="SemiBold" />
                <Border Margin="0,8,0,16"
                        Padding="12"
                        BorderBrush="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                        BorderThickness="1"
                        CornerRadius="4">
                    <StackPanel>
                        <TextBlock Text="{Binding Summary}"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap" />
                        <TextBlock Margin="0,8,0,0"
                                   Text="{Binding Rationale}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Installed driver"
                                   FontWeight="SemiBold" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="{Binding InstalledVersion, StringFormat={}Version: {0}}" />
                        <TextBlock Text="{Binding InstalledDate, StringFormat={}Date: {0}}" />
                        <TextBlock Text="{Binding Provider, StringFormat={}Provider: {0}}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Candidate / latest"
                                   FontWeight="SemiBold" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="{Binding CandidateVersion, StringFormat={}Version: {0}}" />
                        <TextBlock Text="{Binding CandidateDate, StringFormat={}Date: {0}}" />
                        <TextBlock Text="{Binding Source, StringFormat={}Source: {0}}" />
                    </StackPanel>
                </Grid>

                <TextBlock Text="Fit for this computer"
                           FontSize="16"
                           FontWeight="SemiBold" />
                <TextBlock Margin="0,8,0,0"
                           FontWeight="SemiBold"
                           Text="Installed driver" />
                <TextBlock Margin="0,4,0,12"
                           Text="{Binding InstalledSuitability}"
                           TextWrapping="Wrap" />
                <TextBlock FontWeight="SemiBold"
                           Text="Candidate/latest driver" />
                <TextBlock Margin="0,4,0,16"
                           Text="{Binding CandidateSuitability}"
                           TextWrapping="Wrap" />

                <TextBlock Text="Recommended version"
                           FontSize="16"
                           FontWeight="SemiBold" />
                <TextBlock Margin="0,8,0,12"
                           Text="{Binding RecommendedVersion}"
                           TextWrapping="Wrap" />

                <TextBlock Text="AI advice"
                           FontSize="16"
                           FontWeight="SemiBold" />
                <TextBlock Margin="0,8,0,16"
                           Text="{Binding AdvisorNote}"
                           TextWrapping="Wrap" />

                <TextBlock Text="Details"
                           FontSize="16"
                           FontWeight="SemiBold" />
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Risk" FontWeight="SemiBold" />
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Risk}" TextWrapping="Wrap" />
                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,6,0,0" Text="Latest known" FontWeight="SemiBold" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,6,0,0" Text="{Binding LatestKnownVersion}" TextWrapping="Wrap" />
                    <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,6,0,0" Text="Latest date" FontWeight="SemiBold" />
                    <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,6,0,0" Text="{Binding LatestKnownDate}" TextWrapping="Wrap" />
                    <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,6,0,0" Text="Hardware ID" FontWeight="SemiBold" />
                    <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,6,0,0" Text="{Binding HardwareId}" TextWrapping="Wrap" />
                    <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,6,0,0" Text="URL" FontWeight="SemiBold" />
                    <TextBlock Grid.Row="4" Grid.Column="1" Margin="0,6,0,0" Text="{Binding LatestKnownUrl}" TextWrapping="Wrap" />
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2"
                Padding="20,10"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Width="96"
                        Padding="14,5"
                        Content="Copy"
                        Click="Copy_Click" />
                <Button Width="96"
                        Margin="8,0,0,0"
                        Padding="14,5"
                        Content="Close"
                        IsCancel="True"
                        Click="Close_Click" />
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
