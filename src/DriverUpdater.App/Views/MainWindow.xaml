<ui:FluentWindow x:Class="DriverUpdater.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:DriverUpdater.App.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        Title="{DynamicResource App.Title}"
        Icon="pack://application:,,,/Assets/app.ico"
        Width="1200" Height="780"
        MinWidth="980" MinHeight="600"
        Loaded="OnLoaded"
        PreviewMouseLeftButtonDown="OnWindowPreviewMouseLeftButtonDown">

    <Window.Resources>
        <Style x:Key="HeaderIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="AiToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="44" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#FF202124" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="AiButtonRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="AiButtonRoot" Property="Background" Value="#FF2B2B32" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="AiButtonRoot" Property="Background" Value="#FF30245A" />
                                <Setter TargetName="AiButtonRoot" Property="BorderBrush" Value="#FF8B5CF6" />
                                <Setter TargetName="AiButtonRoot" Property="BorderThickness" Value="1" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="AiButtonRoot" Property="Background" Value="#FF3E2D70" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Height="56"
                     Padding="20,0"
                     Title=""
                     Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                     ButtonsForeground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                     ButtonsBackground="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
            <ui:TitleBar.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource App.Title}"
                               FontSize="22"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <Border x:Name="AdminBadge"
                            Margin="14,0,0,0"
                            Padding="10,3"
                            CornerRadius="10"
                            Background="#FF2E7D32"
                            VerticalAlignment="Center">
                        <TextBlock x:Name="AdminBadgeText"
                                   Text="{DynamicResource App.Admin}"
                                   Foreground="White"
                                   FontSize="11"
                                   FontWeight="SemiBold" />
                    </Border>
                    <TextBlock Margin="14,0,0,0"
                               VerticalAlignment="Center"
                               Opacity="0.7"
                               Text="{DynamicResource App.Version}" />
                </StackPanel>
            </ui:TitleBar.Header>

            <ui:TitleBar.TrailingContent>
                <StackPanel
                            Orientation="Horizontal"
                            FlowDirection="LeftToRight"
                            VerticalAlignment="Center">
                    <Button Style="{StaticResource HeaderIconButtonStyle}"
                            ToolTip="Support DriverUpdater"
                            Command="{Binding OpenSupportCommand}">
                        <Viewbox Width="22" Height="22">
                            <Canvas Width="24" Height="24">
                                <Path Data="M4,9 H16 V15 C16,19 13,21 10,21 H9 C6,21 4,19 4,15 Z"
                                      Fill="#FFFFF3E6"
                                      Stroke="#FFB45309"
                                      StrokeThickness="1.4" />
                                <Path Data="M16,11 H18 C21,11 21,16 18,17 H16"
                                      Fill="Transparent"
                                      Stroke="#FFB45309"
                                      StrokeThickness="1.6"
                                      StrokeStartLineCap="Round" />
                                <Path Data="M7,7 C4,5 9,4 7,1"
                                      Fill="Transparent"
                                      Stroke="#FFB45309"
                                      StrokeThickness="1.5"
                                      StrokeStartLineCap="Round" />
                                <Path Data="M12,7 C9,5 14,4 12,1"
                                      Fill="Transparent"
                                      Stroke="#FFB45309"
                                      StrokeThickness="1.5"
                                      StrokeStartLineCap="Round" />
                                <Path Data="M3,22 H18"
                                      Stroke="#FFB45309"
                                      StrokeThickness="1.5"
                                      StrokeStartLineCap="Round" />
                            </Canvas>
                        </Viewbox>
                    </Button>
                    <Button Style="{StaticResource HeaderIconButtonStyle}"
                            ToolTip="{DynamicResource Toolbar.History}"
                            Command="{Binding OpenHistoryCommand}">
                        <TextBlock Text="&#xE81C;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="15" />
                    </Button>
                    <Button Style="{StaticResource HeaderIconButtonStyle}"
                            ToolTip="{DynamicResource Toolbar.Logs}"
                            Command="{Binding OpenLogsCommand}">
                        <TextBlock Text="&#xE8A5;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="15" />
                    </Button>
                    <Button Style="{StaticResource HeaderIconButtonStyle}"
                            ToolTip="{DynamicResource Toolbar.Settings}"
                            Command="{Binding OpenSettingsCommand}">
                        <TextBlock Text="&#xE713;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="15" />
                    </Button>
                </StackPanel>
            </ui:TitleBar.TrailingContent>
        </ui:TitleBar>

        <Border Grid.Row="1"
                Padding="20,10"
                Background="#FFEEF6FF"
                BorderBrush="#FFB6D7FF"
                BorderThickness="0,0,0,1"
                Visibility="{Binding HasOem, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock FontWeight="SemiBold"
                               Foreground="#FF1A4B8A">
                        <Run Text="Detected " /><Run Text="{Binding DetectedOem.Manufacturer}" /><Run Text=" " /><Run Text="{Binding DetectedOem.Model}" />
                    </TextBlock>
                    <TextBlock Margin="0,2,0,0"
                               FontSize="12"
                               Foreground="#FF1A4B8A"
                               TextWrapping="Wrap"
                               Text="For best driver coverage on OEM-specific components (firmware, dock, hotkeys), use the manufacturer's own tool alongside DriverUpdater." />
                </StackPanel>
                <Button Grid.Column="1"
                        Padding="12,4"
                        VerticalAlignment="Center"
                        Content="{Binding DetectedOem.ToolName, StringFormat='Open {0}'}"
                        Command="{Binding OpenOemToolCommand}" />
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Padding="20,12"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <WrapPanel Grid.Row="0" Grid.Column="0" VerticalAlignment="Center">
                    <Button Content="{DynamicResource Toolbar.Scan}"
                            MinWidth="88"
                            Padding="14,6"
                            Command="{Binding ScanCommand}"
                            Style="{DynamicResource AccentButtonStyle}" />
                    <Button Margin="8,0,0,0"
                            MinWidth="72"
                            Padding="14,6"
                            Content="{DynamicResource Toolbar.Cancel}"
                            Command="{Binding ScanCancelCommand}"
                            IsEnabled="{Binding IsScanning}" />
                    <Button Margin="24,0,0,0"
                            MinWidth="108"
                            Padding="14,6"
                            Content="{DynamicResource Toolbar.UpdateAll}"
                            Command="{Binding UpdateAllCommand}"
                            Style="{DynamicResource AccentButtonStyle}" />
                    <Button x:Name="UpdateSelectedButton"
                            Margin="8,0,0,0"
                            MinWidth="132"
                            Padding="14,6"
                            Content="{DynamicResource Toolbar.UpdateSelected}"
                            Command="{Binding UpdateSelectedCommand}"
                            CommandParameter="{Binding ElementName=DriversGrid, Path=SelectedItems}"
                            Visibility="Collapsed" />
                    <Button Margin="24,0,0,0"
                            Padding="14,6"
                            Content="{DynamicResource Toolbar.UpdateApp}"
                            Command="{Binding UpdateAppCommand}"
                            Style="{DynamicResource AccentButtonStyle}"
                            ToolTip="{Binding AppUpdateVersion, StringFormat='Version {0}'}"
                            Visibility="{Binding IsAppUpdateAvailable, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </WrapPanel>

                <ToggleButton Grid.Row="0"
                              Grid.Column="1"
                              Style="{StaticResource AiToggleButtonStyle}"
                              Margin="16,0,0,0"
                              VerticalAlignment="Center"
                              IsChecked="{Binding IsDriverChatVisible, Mode=TwoWay}"
                              ToolTip="Ask AI about your drivers"
                              AutomationProperties.Name="Ask AI about your drivers">
                    <ContentControl Content="{StaticResource AiSparkleIcon}"
                                    LayoutTransform="{StaticResource AiSparkleScale}" />
                </ToggleButton>

                <StackPanel Grid.Row="1"
                            Margin="0,10,0,0"
                            HorizontalAlignment="Right"
                            Orientation="Horizontal">
                    <ui:TextBox Width="240"
                              Margin="0,0,8,0"
                              PlaceholderText="Search device, provider, hardware ID..."
                              Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=150}" />
                    <ComboBox Width="180"
                               ItemsSource="{Binding AvailableCategories}"
                              SelectedItem="{Binding CategoryFilter}" />
                    <ComboBox Width="170"
                              Margin="8,0,0,0"
                              ItemsSource="{Binding AvailableUpdateFilters}"
                              DisplayMemberPath="Label"
                              SelectedValuePath="Value"
                              SelectedValue="{Binding UpdateFilter}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="3" MinWidth="0" ClipToBounds="True">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

        <DataGrid x:Name="DriversGrid"
                  Grid.Column="0"
                  MinWidth="0"
                  Margin="20,12,20,8"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserReorderColumns="False"
                  CanUserResizeColumns="False"
                  CanUserResizeRows="False"
                  FrozenColumnCount="1"
                  GridLinesVisibility="None"
                  HeadersVisibility="Column"
                  IsReadOnly="True"
                  RowHeight="34"
                  SelectionMode="Extended"
                  SelectionUnit="FullRow"
                  SelectionChanged="OnDriverSelectionChanged"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  EnableRowVirtualization="True"
                  EnableColumnVirtualization="True"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  ItemsSource="{Binding DriversView}">
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                    <Setter Property="BorderBrush" Value="Transparent" />
                    <Setter Property="BorderThickness" Value="0" />
                </Style>
            </DataGrid.CellStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="{DynamicResource Grid.Device}"
                                    Binding="{Binding DeviceName}"
                                    Width="*"
                                    MinWidth="260" />
                <DataGridTemplateColumn Header="{DynamicResource Grid.Status}"
                                        Width="170"
                                        MinWidth="170">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid Margin="4,0" VerticalAlignment="Center">
                                <TextBlock VerticalAlignment="Center"
                                           Text="{Binding StatusText}"
                                           TextTrimming="CharacterEllipsis">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <Grid Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <ProgressBar Grid.Row="0"
                                                 Height="6"
                                                 Minimum="0"
                                                 Maximum="100"
                                                 Value="{Binding DownloadPercent, Mode=OneWay}"
                                                 Visibility="{Binding HasDeterminateProgress, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    <ProgressBar Grid.Row="0"
                                                 Height="6"
                                                 IsIndeterminate="True">
                                        <ProgressBar.Style>
                                            <Style TargetType="ProgressBar">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsBusy}" Value="True" />
                                                            <Condition Binding="{Binding HasDeterminateProgress}" Value="False" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ProgressBar.Style>
                                    </ProgressBar>
                                    <TextBlock Grid.Row="1"
                                               Margin="0,2,0,0"
                                               FontSize="11"
                                               Opacity="0.8"
                                               Text="{Binding ProgressStatusText}"
                                               TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="{DynamicResource Grid.DriverVersion}"
                                    Binding="{Binding VersionSummaryText}"
                                    Width="190"
                                    MinWidth="190">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center" />
                            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                            <Setter Property="ToolTip" Value="{Binding DriverDetailsTooltip}" />
                            <Setter Property="ToolTipService.ShowDuration" Value="30000" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTemplateColumn Header="{DynamicResource Grid.Update}"
                                        Width="112"
                                        MinWidth="112">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="{Binding UpdateActionText}"
                                    Padding="8,2"
                                    Margin="2"
                                    IsEnabled="{Binding CanUpdate}"
                                    Command="{Binding DataContext.UpdateSingleCommand, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"
                                    CommandParameter="{Binding}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="{DynamicResource Grid.Ai}"
                                        Width="190"
                                        MinWidth="190">
                    <DataGridTemplateColumn.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                            <Setter Property="BorderThickness" Value="0" />
                        </Style>
                    </DataGridTemplateColumn.CellStyle>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid VerticalAlignment="Center"
                                  Margin="2,0"
                                  ClipToBounds="True">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="66" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0"
                                        Width="58"
                                        Height="24"
                                        Padding="0"
                                        HorizontalAlignment="Left"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        FontSize="12"
                                        IsEnabled="{Binding CanAskAi}"
                                        Command="{Binding DataContext.AskAiCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                        CommandParameter="{Binding}">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="#FF3A3A3A" />
                                            <Setter Property="BorderBrush" Value="#FF555555" />
                                            <Setter Property="Foreground" Value="White" />
                                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="Root"
                                                                Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="2"
                                                                ClipToBounds="True">
                                                            <Grid>
                                                                <ProgressBar Height="{TemplateBinding Height}"
                                                                             IsIndeterminate="True"
                                                                             Foreground="#FF2E7D32"
                                                                             Background="Transparent"
                                                                             BorderThickness="0"
                                                                             Opacity="0.95"
                                                                             Visibility="{Binding IsAiChecking, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                                <ContentPresenter HorizontalAlignment="Center"
                                                                                  VerticalAlignment="Center"
                                                                                  RecognizesAccessKey="True" />
                                                            </Grid>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Root" Property="Background" Value="#FF464646" />
                                                            </Trigger>
                                                            <Trigger Property="IsPressed" Value="True">
                                                                <Setter TargetName="Root" Property="Background" Value="#FF2F5F34" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                    <TextBlock Text="Ask AI"
                                               Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" />
                                </Button>
                                <TextBlock Grid.Column="2"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold"
                                           FontSize="12"
                                           Text="{Binding AiRecommendationText}"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTipService.ShowDuration="30000"
                                           ToolTip="{Binding AiRiskTooltip}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding AiRiskText}" Value="Safe">
                                                    <Setter Property="Foreground" Value="#FF2E7D32" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding AiRiskText}" Value="Caution">
                                                    <Setter Property="Foreground" Value="#FFE08600" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding AiRiskText}" Value="High risk">
                                                    <Setter Property="Foreground" Value="#FFC62828" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

            <GridSplitter Grid.Column="1"
                          Width="4"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          ResizeBehavior="PreviousAndNext"
                          Background="Transparent"
                          Visibility="{Binding IsDriverChatVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />

            <Border Grid.Column="2"
                    Width="380"
                    Margin="0,12,20,8"
                    Padding="12,10"
                    CornerRadius="4"
                    Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                    BorderBrush="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                    BorderThickness="1"
                    Visibility="{Binding IsDriverChatVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <ContentControl Content="{StaticResource AiSparkleIcon}" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="Ask AI about your drivers" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <ProgressBar Width="60" Height="4" Margin="10,0,0,0" VerticalAlignment="Center"
                                     IsIndeterminate="True"
                                     Visibility="{Binding IsDriverChatting, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <Button Margin="10,0,0,0" Padding="8,2" Content="Clear" FontSize="11"
                                Command="{Binding ClearDriverChatCommand}"
                                Visibility="{Binding HasDriverChat, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>

                    <Border Grid.Row="1"
                            Visibility="{Binding HasNoDriverChat, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="Ask about your drivers - what is worth updating, whether an update is safe for this exact hardware, why a driver is flagged, and so on. The AI answers from the current scan, and when it recommends installing specific updates you get a one-click Install button."
                                   TextWrapping="Wrap" Opacity="0.7" FontSize="12" VerticalAlignment="Top" />
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                  Visibility="{Binding HasDriverChat, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ItemsControl ItemsSource="{Binding DriverChatMessages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8" Padding="10,7" CornerRadius="6">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumBrush}" />
                                                <Setter Property="HorizontalAlignment" Value="Left" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource SystemControlHighlightAccentBrush}" />
                                                        <Setter Property="HorizontalAlignment" Value="Right" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="{Binding RoleLabel}" FontSize="10" FontWeight="SemiBold"
                                                       Opacity="0.7" Margin="0,0,0,2">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasInstallAction}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="{Binding Text}" TextWrapping="Wrap" FontSize="12" MaxWidth="310">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasInstallAction}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <Button Padding="14,5"
                                                    FontSize="12"
                                                    HorizontalAlignment="Stretch"
                                                    Style="{DynamicResource AccentButtonStyle}"
                                                    Command="{Binding DataContext.InstallAiRecommendedCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Visibility="{Binding HasInstallAction, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBlock Text="{Binding InstallActionLabel}" TextWrapping="Wrap" TextAlignment="Center" />
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Grid Grid.Row="2" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBox Grid.Column="0"
                                 Text="{Binding DriverChatInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="Ask about your drivers..."
                                 TextWrapping="Wrap" AcceptsReturn="False" MaxLength="1000"
                                 VerticalContentAlignment="Center">
                            <ui:TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding SendDriverChatCommand}" />
                            </ui:TextBox.InputBindings>
                        </ui:TextBox>
                        <Button Grid.Column="1" Margin="8,0,0,0" Padding="14,4" Content="Send"
                                Command="{Binding SendDriverChatCommand}"
                                Style="{DynamicResource AccentButtonStyle}" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="4"
                Padding="20,10"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding StatusText}"
                           Opacity="0.85"
                           VerticalAlignment="Center"
                           FontSize="12" />

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Content="Skip AI search"
                            Margin="0,0,12,0"
                            Padding="12,4"
                            Command="{Binding SkipAiSearchCommand}"
                            Visibility="{Binding IsAiSearchRunning, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <ProgressBar Width="120"
                                 Height="6"
                                 Margin="0,0,12,0"
                                 IsIndeterminate="True"
                                 Visibility="{Binding IsScanning, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <TextBlock Text="{Binding ProgressText}"
                               Opacity="0.7"
                               FontSize="12"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
