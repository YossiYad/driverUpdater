<Window x:Class="DriverUpdater.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:DriverUpdater.App.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        Title="{DynamicResource App.Title}"
        Icon="pack://application:,,,/Assets/app.ico"
        Width="1200" Height="780"
        MinWidth="980" MinHeight="600"
        ui:WindowHelper.UseModernWindowStyle="True"
        Loaded="OnLoaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="20,14"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{DynamicResource App.Title}"
                           FontSize="22"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <Border x:Name="AdminBadge"
                        Margin="14,0,0,0"
                        Padding="10,3"
                        CornerRadius="10"
                        Background="#FF2E7D32"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="AdminBadgeText"
                               Text="{DynamicResource App.Admin}"
                               Foreground="White"
                               FontSize="11"
                               FontWeight="SemiBold" />
                </Border>
                <TextBlock Margin="14,0,0,0"
                           VerticalAlignment="Center"
                           Opacity="0.7"
                           Text="{DynamicResource App.Version}" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Padding="20,10"
                Background="#FFEEF6FF"
                BorderBrush="#FFB6D7FF"
                BorderThickness="0,0,0,1"
                Visibility="{Binding HasOem, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock FontWeight="SemiBold"
                               Foreground="#FF1A4B8A">
                        <Run Text="Detected " /><Run Text="{Binding DetectedOem.Manufacturer}" /><Run Text=" " /><Run Text="{Binding DetectedOem.Model}" />
                    </TextBlock>
                    <TextBlock Margin="0,2,0,0"
                               FontSize="12"
                               Foreground="#FF1A4B8A"
                               TextWrapping="Wrap"
                               Text="For best driver coverage on OEM-specific components (firmware, dock, hotkeys), use the manufacturer's own tool alongside DriverUpdater." />
                </StackPanel>
                <Button Grid.Column="1"
                        Padding="12,4"
                        VerticalAlignment="Center"
                        Content="{Binding DetectedOem.ToolName, StringFormat='Open {0}'}"
                        Command="{Binding OpenOemToolCommand}" />
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Padding="20,12"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <WrapPanel Grid.Row="0" VerticalAlignment="Center">
                    <Button Content="{DynamicResource Toolbar.Scan}"
                            Padding="14,6"
                            Command="{Binding ScanCommand}"
                            Style="{DynamicResource AccentButtonStyle}" />
                    <Button Margin="8,0,0,0"
                            Padding="14,6"
                            Content="{DynamicResource Toolbar.Cancel}"
                            Command="{Binding ScanCancelCommand}"
                            IsEnabled="{Binding IsScanning}" />
                    <Button Margin="8,0,0,0"
                            Padding="14,6"
                            Content="{DynamicResource Toolbar.Clear}"
                            Command="{Binding ClearCommand}" />
                    <Button Margin="24,0,0,0"
                            Padding="14,6"
                            Content="{DynamicResource Toolbar.UpdateAll}"
                            Command="{Binding UpdateAllCommand}"
                            Style="{DynamicResource AccentButtonStyle}" />
                    <Button Margin="8,0,0,0"
                            Padding="14,6"
                            Content="{DynamicResource Toolbar.UpdateSelected}"
                            Command="{Binding UpdateSelectedCommand}"
                            CommandParameter="{Binding ElementName=DriversGrid, Path=SelectedItems}" />
                    <Button Margin="8,0,0,0"
                            Padding="14,6"
                            Content="{DynamicResource Toolbar.UpdateOutdated}"
                            Command="{Binding UpdateOutdatedCommand}" />
                    <Button Margin="8,0,0,0"
                            Padding="14,6"
                            Content="{DynamicResource Toolbar.InstallConfirmed}"
                            Command="{Binding InstallConfirmedCommand}" />
                    <Button Margin="8,0,0,0"
                            Padding="14,6"
                            Content="{DynamicResource Toolbar.AskAiAll}"
                            Command="{Binding AskAiAllCommand}" />
                    <Button Margin="8,0,0,0"
                            Padding="14,6"
                            Content="{DynamicResource Toolbar.DryRun}"
                            Command="{Binding DryRunOutdatedCommand}" />
                    <Button Margin="24,0,0,0"
                            Padding="14,6"
                            Content="{DynamicResource Toolbar.History}"
                            Command="{Binding OpenHistoryCommand}" />
                    <Button Margin="8,0,0,0"
                            Padding="14,6"
                            Content="{DynamicResource Toolbar.Logs}"
                            Command="{Binding OpenLogsCommand}" />
                    <Button Margin="8,0,0,0"
                            Padding="14,6"
                            Content="{DynamicResource Toolbar.Settings}"
                            Command="{Binding OpenSettingsCommand}" />
                    <Button Margin="24,0,0,0"
                            Padding="14,6"
                            Content="{DynamicResource Toolbar.UpdateApp}"
                            Command="{Binding UpdateAppCommand}"
                            Style="{DynamicResource AccentButtonStyle}"
                            ToolTip="{Binding AppUpdateVersion, StringFormat='Version {0}'}"
                            Visibility="{Binding IsAppUpdateAvailable, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </WrapPanel>

                <StackPanel Grid.Row="1"
                            Margin="0,10,0,0"
                            HorizontalAlignment="Right"
                            Orientation="Horizontal">
                    <ToggleButton Margin="0,0,8,0"
                                  Padding="10,4"
                                  VerticalAlignment="Center"
                                  IsChecked="{Binding IsDriverChatVisible, Mode=TwoWay}"
                                  ToolTip="Ask AI about your drivers">
                        <TextBlock Text="&#x2726;&#x2727;"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource AiSparkleBrush}" />
                    </ToggleButton>
                    <TextBox Width="240"
                             Margin="0,0,8,0"
                             ui:ControlHelper.PlaceholderText="Search device, provider, hardware ID..."
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=150}" />
                    <ComboBox Width="180"
                              ui:ControlHelper.PlaceholderText="All categories"
                              ItemsSource="{Binding AvailableCategories}"
                              SelectedItem="{Binding CategoryFilter}" />
                    <ComboBox Width="170"
                              Margin="8,0,0,0"
                              ItemsSource="{Binding AvailableUpdateFilters}"
                              DisplayMemberPath="Label"
                              SelectedValuePath="Value"
                              SelectedValue="{Binding UpdateFilter}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

        <DataGrid x:Name="DriversGrid"
                  Grid.Column="0"
                  Margin="20,12,20,8"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeRows="False"
                  GridLinesVisibility="None"
                  HeadersVisibility="Column"
                  IsReadOnly="True"
                  RowHeight="34"
                  SelectionMode="Extended"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  EnableRowVirtualization="True"
                  ItemsSource="{Binding DriversView}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Status"
                                    Binding="{Binding Status}"
                                    Width="90" />
                <DataGridTextColumn Header="Device"
                                    Binding="{Binding DeviceName}"
                                    Width="*"
                                    MinWidth="200" />
                <DataGridTextColumn Header="Category"
                                    Binding="{Binding Category}"
                                    Width="110" />
                <DataGridTextColumn Header="Version"
                                    Binding="{Binding CurrentVersionText}"
                                    Width="120" />
                <DataGridTextColumn Header="Date"
                                    Binding="{Binding CurrentDateText}"
                                    Width="100" />
                <DataGridTextColumn Header="Available"
                                    Binding="{Binding AvailableVersionText}"
                                    Width="120" />
                <DataGridTextColumn Header="Available date"
                                    Binding="{Binding AvailableDateText}"
                                    Width="110" />
                <DataGridTextColumn Header="Source"
                                    Binding="{Binding SourceText}"
                                    Width="110" />
                <DataGridTemplateColumn Header="{DynamicResource Grid.Progress}" Width="220">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid VerticalAlignment="Center"
                                  Margin="4,0"
                                  Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <ProgressBar Grid.Row="0"
                                             Height="6"
                                             Minimum="0"
                                             Maximum="100"
                                             Value="{Binding DownloadPercent, Mode=OneWay}"
                                             Visibility="{Binding HasDeterminateProgress, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <ProgressBar Grid.Row="0"
                                             Height="6"
                                             IsIndeterminate="True">
                                    <ProgressBar.Style>
                                        <Style TargetType="ProgressBar">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding IsBusy}" Value="True" />
                                                        <Condition Binding="{Binding HasDeterminateProgress}" Value="False" />
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ProgressBar.Style>
                                </ProgressBar>
                                <TextBlock Grid.Row="1"
                                           Margin="0,2,0,0"
                                           FontSize="11"
                                           Opacity="0.8"
                                           Text="{Binding ProgressStatusText}"
                                           TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="{DynamicResource Grid.Update}" Width="140">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="{Binding UpdateActionText}"
                                    Padding="8,2"
                                    Margin="2"
                                    IsEnabled="{Binding CanUpdate}"
                                    Command="{Binding DataContext.UpdateSingleCommand, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"
                                    CommandParameter="{Binding}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Confidence"
                                    Binding="{Binding ConfidenceText}"
                                    Width="110" />
                <DataGridTemplateColumn Header="{DynamicResource Grid.Ai}" Width="190" MinWidth="190">
                    <DataGridTemplateColumn.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                            <Setter Property="BorderThickness" Value="0" />
                        </Style>
                    </DataGridTemplateColumn.CellStyle>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid VerticalAlignment="Center"
                                  Margin="2,0"
                                  ClipToBounds="True">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="66" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0"
                                        Width="58"
                                        Height="24"
                                        Padding="0"
                                        HorizontalAlignment="Left"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        FontSize="12"
                                        Command="{Binding DataContext.AskAiCommand, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"
                                        CommandParameter="{Binding}">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="#FF3A3A3A" />
                                            <Setter Property="BorderBrush" Value="#FF555555" />
                                            <Setter Property="Foreground" Value="White" />
                                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="Root"
                                                                Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="2"
                                                                ClipToBounds="True">
                                                            <Grid>
                                                                <ProgressBar Height="{TemplateBinding Height}"
                                                                             IsIndeterminate="True"
                                                                             Foreground="#FF2E7D32"
                                                                             Background="Transparent"
                                                                             BorderThickness="0"
                                                                             Opacity="0.95"
                                                                             Visibility="{Binding IsAiChecking, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                                <ContentPresenter HorizontalAlignment="Center"
                                                                                  VerticalAlignment="Center"
                                                                                  RecognizesAccessKey="True" />
                                                            </Grid>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Root" Property="Background" Value="#FF464646" />
                                                            </Trigger>
                                                            <Trigger Property="IsPressed" Value="True">
                                                                <Setter TargetName="Root" Property="Background" Value="#FF2F5F34" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                    <TextBlock Text="Ask AI"
                                               Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" />
                                </Button>
                                <TextBlock Grid.Column="2"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold"
                                           FontSize="12"
                                           Text="{Binding AiRecommendationText}"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTipService.ShowDuration="30000"
                                           ToolTip="{Binding AiRiskTooltip}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding AiRiskText}" Value="Safe">
                                                    <Setter Property="Foreground" Value="#FF2E7D32" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding AiRiskText}" Value="Caution">
                                                    <Setter Property="Foreground" Value="#FFE08600" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding AiRiskText}" Value="High risk">
                                                    <Setter Property="Foreground" Value="#FFC62828" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Provider"
                                    Binding="{Binding Provider}"
                                    Width="160" />
            </DataGrid.Columns>
        </DataGrid>

            <GridSplitter Grid.Column="1"
                          Width="4"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          ResizeBehavior="PreviousAndNext"
                          Background="Transparent"
                          Visibility="{Binding IsDriverChatVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />

            <Border Grid.Column="2"
                    Width="380"
                    Margin="0,12,20,8"
                    Padding="12,10"
                    CornerRadius="4"
                    Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                    BorderBrush="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                    BorderThickness="1"
                    Visibility="{Binding IsDriverChatVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="&#x2726;&#x2727;" FontSize="15" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="0,0,6,0"
                                   Foreground="{StaticResource AiSparkleBrush}" />
                        <TextBlock Text="Ask AI about your drivers" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <ProgressBar Width="60" Height="4" Margin="10,0,0,0" VerticalAlignment="Center"
                                     IsIndeterminate="True"
                                     Visibility="{Binding IsDriverChatting, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <Button Margin="10,0,0,0" Padding="8,2" Content="Clear" FontSize="11"
                                Command="{Binding ClearDriverChatCommand}"
                                Visibility="{Binding HasDriverChat, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>

                    <Border Grid.Row="1"
                            Visibility="{Binding HasNoDriverChat, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="Ask about your drivers - what is worth updating, whether an update is safe for this exact hardware, why a driver is flagged, and so on. The AI answers from the current scan."
                                   TextWrapping="Wrap" Opacity="0.7" FontSize="12" VerticalAlignment="Top" />
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                  Visibility="{Binding HasDriverChat, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ItemsControl ItemsSource="{Binding DriverChatMessages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8" Padding="10,7" CornerRadius="6">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumBrush}" />
                                                <Setter Property="HorizontalAlignment" Value="Left" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource SystemControlHighlightAccentBrush}" />
                                                        <Setter Property="HorizontalAlignment" Value="Right" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="{Binding RoleLabel}" FontSize="10" FontWeight="SemiBold"
                                                       Opacity="0.7" Margin="0,0,0,2" />
                                            <TextBlock Text="{Binding Text}" TextWrapping="Wrap" FontSize="12" MaxWidth="310" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Grid Grid.Row="2" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding DriverChatInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 ui:ControlHelper.PlaceholderText="Ask about your drivers..."
                                 TextWrapping="Wrap" AcceptsReturn="False" MaxLength="1000"
                                 VerticalContentAlignment="Center">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding SendDriverChatCommand}" />
                            </TextBox.InputBindings>
                        </TextBox>
                        <Button Grid.Column="1" Margin="8,0,0,0" Padding="14,4" Content="Send"
                                Command="{Binding SendDriverChatCommand}"
                                Style="{DynamicResource AccentButtonStyle}" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="4"
                Padding="20,10"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding StatusText}"
                           Opacity="0.85"
                           VerticalAlignment="Center"
                           FontSize="12" />

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <ProgressBar Width="120"
                                 Height="6"
                                 Margin="0,0,12,0"
                                 IsIndeterminate="True"
                                 Visibility="{Binding IsScanning, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <TextBlock Text="{Binding ProgressText}"
                               Opacity="0.7"
                               FontSize="12"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
