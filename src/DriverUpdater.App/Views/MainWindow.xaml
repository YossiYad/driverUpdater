<Window x:Class="DriverUpdater.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:DriverUpdater.App.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        Title="{DynamicResource App.Title}"
        Icon="pack://application:,,,/Assets/app.ico"
        Width="1200" Height="780"
        MinWidth="980" MinHeight="600"
        ui:WindowHelper.UseModernWindowStyle="True"
        Loaded="OnLoaded">

    <Window.Resources>
        <Style x:Key="HeaderIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="15" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="20,12"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource App.Title}"
                               FontSize="22"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <Border x:Name="AdminBadge"
                            Margin="14,0,0,0"
                            Padding="10,3"
                            CornerRadius="10"
                            Background="#FF2E7D32"
                            VerticalAlignment="Center">
                        <TextBlock x:Name="AdminBadgeText"
                                   Text="{DynamicResource App.Admin}"
                                   Foreground="White"
                                   FontSize="11"
                                   FontWeight="SemiBold" />
                    </Border>
                    <TextBlock Margin="14,0,0,0"
                               VerticalAlignment="Center"
                               Opacity="0.7"
                               Text="{DynamicResource App.Version}" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Style="{StaticResource HeaderIconButtonStyle}"
                            Content="&#xE81C;"
                            ToolTip="{DynamicResource Toolbar.History}"
                            Command="{Binding OpenHistoryCommand}" />
                    <Button Style="{StaticResource HeaderIconButtonStyle}"
                            Content="&#xE8A5;"
                            ToolTip="{DynamicResource Toolbar.Logs}"
                            Command="{Binding OpenLogsCommand}" />
                    <Button Style="{StaticResource HeaderIconButtonStyle}"
                            Content="&#xE713;"
                            ToolTip="{DynamicResource Toolbar.Settings}"
                            Command="{Binding OpenSettingsCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Padding="20,10"
                Background="#FFEEF6FF"
                BorderBrush="#FFB6D7FF"
                BorderThickness="0,0,0,1"
                Visibility="{Binding HasOem, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock FontWeight="SemiBold"
                               Foreground="#FF1A4B8A">
                        <Run Text="Detected " /><Run Text="{Binding DetectedOem.Manufacturer}" /><Run Text=" " /><Run Text="{Binding DetectedOem.Model}" />
                    </TextBlock>
                    <TextBlock Margin="0,2,0,0"
                               FontSize="12"
                               Foreground="#FF1A4B8A"
                               TextWrapping="Wrap"
                               Text="For best driver coverage on OEM-specific components (firmware, dock, hotkeys), use the manufacturer's own tool alongside DriverUpdater." />
                </StackPanel>
                <Button Grid.Column="1"
                        Padding="12,4"
                        VerticalAlignment="Center"
                        Content="{Binding DetectedOem.ToolName, StringFormat='Open {0}'}"
                        Command="{Binding OpenOemToolCommand}" />
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Padding="20,12"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <WrapPanel Grid.Row="0" VerticalAlignment="Center">
                    <Button Content="{DynamicResource Toolbar.Scan}"
                            MinWidth="88"
                            Padding="14,6"
                            Command="{Binding ScanCommand}"
                            Style="{DynamicResource AccentButtonStyle}" />
                    <Button Margin="8,0,0,0"
                            MinWidth="72"
                            Padding="14,6"
                            Content="{DynamicResource Toolbar.Cancel}"
                            Command="{Binding ScanCancelCommand}"
                            IsEnabled="{Binding IsScanning}" />
                    <Button Margin="8,0,0,0"
                            MinWidth="72"
                            Padding="14,6"
                            Content="{DynamicResource Toolbar.Clear}"
                            Command="{Binding ClearCommand}" />
                    <Button Margin="24,0,0,0"
                            MinWidth="108"
                            Padding="14,6"
                            Content="{DynamicResource Toolbar.UpdateAll}"
                            Command="{Binding UpdateAllCommand}"
                            Style="{DynamicResource AccentButtonStyle}" />
                    <Button Margin="8,0,0,0"
                            MinWidth="132"
                            Padding="14,6"
                            Content="{DynamicResource Toolbar.UpdateSelected}"
                            Command="{Binding UpdateSelectedCommand}"
                            CommandParameter="{Binding ElementName=DriversGrid, Path=SelectedItems}" />
                    <Button Margin="8,0,0,0"
                            MinWidth="132"
                            Padding="14,6"
                            Content="{DynamicResource Toolbar.UpdateOutdated}"
                            Command="{Binding UpdateOutdatedCommand}" />
                    <Button Margin="8,0,0,0"
                            MinWidth="132"
                            Padding="14,6"
                            Content="{DynamicResource Toolbar.InstallConfirmed}"
                            Command="{Binding InstallConfirmedCommand}" />
                    <Button Margin="8,0,0,0"
                            MinWidth="86"
                            Padding="14,6"
                            Content="{DynamicResource Toolbar.AskAiAll}"
                            Command="{Binding AskAiAllCommand}" />
                    <Button Margin="8,0,0,0"
                            MinWidth="76"
                            Padding="14,6"
                            Content="{DynamicResource Toolbar.DryRun}"
                            Command="{Binding DryRunOutdatedCommand}" />
                </WrapPanel>

                <Grid Grid.Row="1"
                      Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="170" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             MinWidth="280"
                             Margin="0,0,8,0"
                             ui:ControlHelper.PlaceholderText="Search device, provider, hardware ID..."
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=150}" />
                    <ComboBox Grid.Column="1"
                              Margin="0,0,8,0"
                              ui:ControlHelper.PlaceholderText="All categories"
                              ItemsSource="{Binding AvailableCategories}"
                              SelectedItem="{Binding CategoryFilter}" />
                    <ComboBox Grid.Column="2"
                              ItemsSource="{Binding AvailableUpdateFilters}"
                              DisplayMemberPath="Label"
                              SelectedValuePath="Value"
                              SelectedValue="{Binding UpdateFilter}" />
                </Grid>
            </Grid>
        </Border>

        <DataGrid x:Name="DriversGrid"
                  Grid.Row="3"
                  Margin="20,12,20,8"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeRows="False"
                  GridLinesVisibility="None"
                  HeadersVisibility="Column"
                  IsReadOnly="True"
                  RowHeight="34"
                  SelectionMode="Extended"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  EnableRowVirtualization="True"
                  EnableColumnVirtualization="True"
                  ItemsSource="{Binding DriversView}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Status"
                                    Binding="{Binding Status}"
                                    Width="74" />
                <DataGridTextColumn Header="Device"
                                    Binding="{Binding DeviceName}"
                                    Width="2*"
                                    MinWidth="260" />
                <DataGridTextColumn Header="Category"
                                    Binding="{Binding Category}"
                                    Width="92" />
                <DataGridTextColumn Header="Version"
                                    Binding="{Binding CurrentVersionText}"
                                    Width="92" />
                <DataGridTextColumn Header="Date"
                                    Binding="{Binding CurrentDateText}"
                                    Width="82" />
                <DataGridTextColumn Header="Available"
                                    Binding="{Binding AvailableVersionText}"
                                    Width="96" />
                <DataGridTextColumn Header="Avail. date"
                                    Binding="{Binding AvailableDateText}"
                                    Width="92" />
                <DataGridTextColumn Header="Source"
                                    Binding="{Binding SourceText}"
                                    Width="86" />
                <DataGridTemplateColumn Header="{DynamicResource Grid.Progress}" Width="170">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid VerticalAlignment="Center"
                                  Margin="4,0"
                                  Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <ProgressBar Grid.Row="0"
                                             Height="6"
                                             Minimum="0"
                                             Maximum="100"
                                             Value="{Binding DownloadPercent, Mode=OneWay}"
                                             Visibility="{Binding HasDeterminateProgress, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <ProgressBar Grid.Row="0"
                                             Height="6"
                                             IsIndeterminate="True">
                                    <ProgressBar.Style>
                                        <Style TargetType="ProgressBar">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding IsBusy}" Value="True" />
                                                        <Condition Binding="{Binding HasDeterminateProgress}" Value="False" />
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ProgressBar.Style>
                                </ProgressBar>
                                <TextBlock Grid.Row="1"
                                           Margin="0,2,0,0"
                                           FontSize="11"
                                           Opacity="0.8"
                                           Text="{Binding ProgressStatusText}"
                                           TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="{DynamicResource Grid.Update}" Width="118">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="{Binding UpdateActionText}"
                                    Padding="8,2"
                                    Margin="2"
                                    IsEnabled="{Binding CanUpdate}"
                                    Command="{Binding DataContext.UpdateSingleCommand, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"
                                    CommandParameter="{Binding}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Confidence"
                                    Binding="{Binding ConfidenceText}"
                                    Width="96" />
                <DataGridTemplateColumn Header="{DynamicResource Grid.Ai}" Width="170" MinWidth="150">
                    <DataGridTemplateColumn.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                            <Setter Property="BorderThickness" Value="0" />
                        </Style>
                    </DataGridTemplateColumn.CellStyle>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid VerticalAlignment="Center"
                                  Margin="2,0"
                                  ClipToBounds="True">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="66" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0"
                                        Width="58"
                                        Height="24"
                                        Padding="0"
                                        HorizontalAlignment="Left"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        FontSize="12"
                                        Command="{Binding DataContext.AskAiCommand, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"
                                        CommandParameter="{Binding}">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="#FF3A3A3A" />
                                            <Setter Property="BorderBrush" Value="#FF555555" />
                                            <Setter Property="Foreground" Value="White" />
                                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="Root"
                                                                Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="2"
                                                                ClipToBounds="True">
                                                            <Grid>
                                                                <ProgressBar Height="{TemplateBinding Height}"
                                                                             IsIndeterminate="True"
                                                                             Foreground="#FF2E7D32"
                                                                             Background="Transparent"
                                                                             BorderThickness="0"
                                                                             Opacity="0.95"
                                                                             Visibility="{Binding IsAiChecking, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                                <ContentPresenter HorizontalAlignment="Center"
                                                                                  VerticalAlignment="Center"
                                                                                  RecognizesAccessKey="True" />
                                                            </Grid>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Root" Property="Background" Value="#FF464646" />
                                                            </Trigger>
                                                            <Trigger Property="IsPressed" Value="True">
                                                                <Setter TargetName="Root" Property="Background" Value="#FF2F5F34" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                    <TextBlock Text="Ask AI"
                                               Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" />
                                </Button>
                                <TextBlock Grid.Column="2"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold"
                                           FontSize="12"
                                           Text="{Binding AiRecommendationText}"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTipService.ShowDuration="30000"
                                           ToolTip="{Binding AiRiskTooltip}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding AiRiskText}" Value="Safe">
                                                    <Setter Property="Foreground" Value="#FF2E7D32" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding AiRiskText}" Value="Caution">
                                                    <Setter Property="Foreground" Value="#FFE08600" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding AiRiskText}" Value="High risk">
                                                    <Setter Property="Foreground" Value="#FFC62828" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Provider"
                                    Binding="{Binding Provider}"
                                    Width="140" />
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="4"
                Padding="20,10"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding StatusText}"
                           Opacity="0.85"
                           VerticalAlignment="Center"
                           FontSize="12" />

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <ProgressBar Width="120"
                                 Height="6"
                                 Margin="0,0,12,0"
                                 IsIndeterminate="True"
                                 Visibility="{Binding IsScanning, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <TextBlock Text="{Binding ProgressText}"
                               Opacity="0.7"
                               FontSize="12"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
