<ui:FluentWindow x:Class="DriverUpdater.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:DriverUpdater.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}"
        Title="DriverUpdater - Settings"
        Icon="pack://application:,,,/Assets/app.ico"
        Width="720" Height="640"
        MinWidth="640" MinHeight="500"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        Loaded="OnLoaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Margin="16">
            <TabItem Header="Sources">
                <StackPanel Margin="16">
                    <CheckBox IsChecked="{Binding EnableWindowsUpdate}"
                              Content="Windows Update (recommended)"
                              IsEnabled="False" />
                    <TextBlock Margin="22,2,0,12"
                               Opacity="0.7"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Text="Always on. Provides safe, signed driver updates from Microsoft." />

                    <CheckBox IsChecked="{Binding EnableMicrosoftCatalog}"
                              Content="Microsoft Update Catalog (opt-in)" />
                    <TextBlock Margin="22,2,0,12"
                               Opacity="0.7"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Text="Queries catalog.update.microsoft.com per hardware ID. Wider coverage than Windows Update alone. Use at your own discretion." />

                    <CheckBox IsChecked="{Binding EnableOemHints}"
                              Content="OEM tool hints" />
                    <TextBlock Margin="22,2,0,12"
                               Opacity="0.7"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Text="Shows a banner pointing to the manufacturer tool (Lenovo Vantage, Dell Command Update, ...) when one is detected." />
                </StackPanel>
            </TabItem>

            <TabItem Header="Safety">
                <StackPanel Margin="16">
                    <CheckBox IsChecked="{Binding CreateRestorePoint}"
                              Content="Create a System Restore point before any update batch" />
                    <CheckBox Margin="0,8,0,0"
                              IsChecked="{Binding BackupBeforeInstall}"
                              Content="Back up the current driver before installing a new one" />
                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                        <TextBlock VerticalAlignment="Center" Text="Keep backups for" />
                        <TextBox Width="60"
                                 Margin="8,0,8,0"
                                 Text="{Binding BackupRetentionDays}" />
                        <TextBlock VerticalAlignment="Center" Text="days" />
                    </StackPanel>
                    <Separator Margin="0,16,0,8" />
                    <TextBlock FontWeight="SemiBold" Text="Advanced scraping" />
                    <CheckBox Margin="0,8,0,0"
                              IsChecked="{Binding EnablePlaywrightFallback}"
                              Content="Use headless browser as fallback when motherboard vendor API is blocked (~250 MB Chromium download on first use)" />
                    <TextBlock Margin="22,4,0,0"
                               Opacity="0.7"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Text="When Gigabyte/ASUS/MSI/etc. block the lightweight API call (Akamai 403), the app boots a headless Chromium and reads the rendered DOM. First run downloads ~250 MB of browser binaries; subsequent runs reuse them." />
                </StackPanel>
            </TabItem>

            <TabItem Header="Schedule">
                <StackPanel Margin="16">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Width="120" VerticalAlignment="Center" Text="Mode" />
                        <ComboBox Width="220"
                                  ItemsSource="{Binding AvailableModes}"
                                  SelectedItem="{Binding ScheduleMode}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Width="120" VerticalAlignment="Center" Text="Cadence" />
                        <ComboBox Width="220"
                                  ItemsSource="{Binding AvailableCadences}"
                                  SelectedItem="{Binding ScheduleCadence}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Width="120" VerticalAlignment="Center" Text="Day of week" />
                        <ComboBox Width="220"
                                  ItemsSource="{Binding AvailableDays}"
                                  SelectedItem="{Binding ScheduleDayOfWeek}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Width="120" VerticalAlignment="Center" Text="Time" />
                        <TextBox Width="120"
                                 Text="{Binding ScheduleTimeOfDay, StringFormat=HH:mm}" />
                    </StackPanel>

                    <Border Padding="14,10"
                            CornerRadius="6"
                            Margin="0,12,0,0"
                            Background="#FFFFF4E5"
                            Visibility="{Binding ShowAutoUpdateWarning, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold"
                                       Foreground="#FF8B5A00"
                                       Text="Caution: automatic updates run unattended" />
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="#FF8B5A00"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Text="The scheduled task will install drivers without your interaction. A bad GPU or storage driver may prevent the machine from booting. Restore point + backup mitigate but do not eliminate this risk." />
                            <CheckBox Margin="0,8,0,0"
                                      IsChecked="{Binding AcceptedAutoUpdateRisk}"
                                      Content="I understand and want to enable automatic updates" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </TabItem>

            <TabItem Header="{DynamicResource Settings.Tab.Language}">
                <StackPanel Margin="16">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Width="120"
                                   VerticalAlignment="Center"
                                   Text="{DynamicResource Settings.Language.Label}" />
                        <ComboBox Width="220"
                                  ItemsSource="{Binding AvailableLanguages}"
                                  SelectedItem="{Binding SelectedLanguage}" />
                    </StackPanel>
                    <TextBlock Opacity="0.7"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Text="{DynamicResource Settings.Language.Hint}" />
                </StackPanel>
            </TabItem>

            <TabItem Header="{DynamicResource Settings.Tab.Ai}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16">
                        <TextBlock TextWrapping="Wrap"
                                   Opacity="0.8"
                                   FontSize="12"
                                   Margin="0,0,0,12"
                                   Text="{DynamicResource Settings.Ai.Intro}" />

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Width="120"
                                       VerticalAlignment="Center"
                                       Text="{DynamicResource Settings.Ai.Provider}" />
                            <ComboBox Width="220"
                                      ItemsSource="{Binding AvailableAiProviders}"
                                      SelectedItem="{Binding SelectedAiProvider}" />
                        </StackPanel>

                        <Border Padding="14,12"
                                CornerRadius="6"
                                Margin="0,8,0,0"
                                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                                Visibility="{Binding IsGeminiSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Text="Google Gemini" />
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <TextBlock Width="120" VerticalAlignment="Center" Text="{DynamicResource Settings.Ai.ApiKey}" />
                                    <PasswordBox x:Name="GeminiKeyBox"
                                                 Width="320"
                                                 PasswordChanged="OnGeminiKeyChanged" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <TextBlock Width="120" VerticalAlignment="Center" Text="{DynamicResource Settings.Ai.Model}" />
                                    <TextBox Width="320" Text="{Binding GeminiModel}" />
                                </StackPanel>
                                <CheckBox Margin="0,10,0,0"
                                          IsChecked="{Binding EnableAiWebSearch}"
                                          Content="{DynamicResource Settings.Ai.WebSearch}" />

                                <Expander Margin="0,12,0,0"
                                          Header="{DynamicResource Settings.Ai.GeminiGuideHeader}">
                                    <StackPanel Margin="0,8,0,0">
                                        <TextBlock TextWrapping="Wrap"
                                                   FontSize="12"
                                                   Opacity="0.9"
                                                   Text="{DynamicResource Settings.Ai.GeminiGuideBody}" />
                                        <TextBlock Margin="0,8,0,0" FontSize="12">
                                            <Hyperlink NavigateUri="https://aistudio.google.com/apikey"
                                                       RequestNavigate="OnHyperlinkRequestNavigate">
                                                <Run Text="https://aistudio.google.com/apikey" />
                                            </Hyperlink>
                                        </TextBlock>
                                    </StackPanel>
                                </Expander>
                            </StackPanel>
                        </Border>

                        <Border Padding="14,12"
                                CornerRadius="6"
                                Margin="0,8,0,0"
                                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                                Visibility="{Binding IsOllamaSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Text="Ollama (local)" />
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <TextBlock Width="120" VerticalAlignment="Center" Text="{DynamicResource Settings.Ai.OllamaUrl}" />
                                    <TextBox Width="320" Text="{Binding OllamaBaseUrl}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <TextBlock Width="120" VerticalAlignment="Center" Text="{DynamicResource Settings.Ai.Model}" />
                                    <TextBox Width="320" Text="{Binding OllamaModel}" />
                                </StackPanel>

                                <Expander Margin="0,12,0,0"
                                          Header="{DynamicResource Settings.Ai.OllamaGuideHeader}">
                                    <StackPanel Margin="0,8,0,0">
                                        <TextBlock TextWrapping="Wrap"
                                                   FontSize="12"
                                                   Opacity="0.9"
                                                   Text="{DynamicResource Settings.Ai.OllamaGuideBody}" />
                                        <TextBlock Margin="0,8,0,0" FontSize="12">
                                            <Hyperlink NavigateUri="https://ollama.com/download"
                                                       RequestNavigate="OnHyperlinkRequestNavigate">
                                                <Run Text="https://ollama.com/download" />
                                            </Hyperlink>
                                        </TextBlock>
                                    </StackPanel>
                                </Expander>
                            </StackPanel>
                        </Border>

                        <Border Padding="14,10"
                                CornerRadius="6"
                                Margin="0,12,0,0"
                                Background="#FFFFF4E5">
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="#FF8B5A00"
                                       FontSize="12"
                                       Text="{DynamicResource Settings.Ai.KeyWarning}" />
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="About">
                <StackPanel Margin="16">
                    <TextBlock Text="{DynamicResource App.Version}" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock Margin="0,8,0,0" Opacity="0.7">
                        <Run Text="Settings file: " /><Run Text="{Binding SettingsPath, Mode=OneWay}" />
                    </TextBlock>

                    <StackPanel Margin="0,20,0,0"
                                Visibility="{Binding CanCheckForUpdates, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <Button Padding="14,6"
                                    Content="Check for updates"
                                    Command="{Binding CheckForUpdatesCommand}" />
                            <ProgressBar Width="120"
                                         Height="4"
                                         Margin="12,0,0,0"
                                         VerticalAlignment="Center"
                                         IsIndeterminate="True"
                                         Visibility="{Binding IsCheckingForUpdates, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </StackPanel>
                        <TextBlock Margin="0,8,0,0"
                                   Opacity="0.7"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Text="Checks GitHub for a newer version. If one is found you'll be asked to install it - the app downloads it and restarts, no need to close and reopen." />

                        <CheckBox Margin="0,16,0,0"
                                  Content="Automatically check for updates on startup"
                                  IsChecked="{Binding CheckForUpdatesOnStartup, Mode=TwoWay}" />
                        <CheckBox Margin="0,8,0,0"
                                  Content="Install updates automatically (no prompt)"
                                  IsEnabled="{Binding CheckForUpdatesOnStartup}"
                                  IsChecked="{Binding AutoInstallAppUpdates, Mode=TwoWay}" />
                        <TextBlock Margin="0,6,0,0"
                                   Opacity="0.7"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Text="With automatic install on, a found update is downloaded and applied on startup and the app restarts onto the new version." />
                    </StackPanel>
                </StackPanel>
            </TabItem>
        </TabControl>

        <Border Grid.Row="1"
                Padding="16,10"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           VerticalAlignment="Center"
                           Opacity="0.85"
                           FontSize="12"
                           Text="{Binding StatusText}" />
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button MinWidth="100"
                            Content="Close"
                            IsCancel="True"
                            Click="OnClose" />
                    <Button MinWidth="100"
                            Margin="8,0,0,0"
                            Style="{DynamicResource AccentButtonStyle}"
                            Content="Save"
                            Command="{Binding SaveCommand}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
