<ui:FluentWindow x:Class="DriverUpdater.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:models="clr-namespace:DriverUpdater.Core.Models;assembly=DriverUpdater.Core"
        xmlns:vm="clr-namespace:DriverUpdater.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}"
        Title="DriverUpdater - Settings"
        Icon="pack://application:,,,/Assets/app.ico"
        Width="760" Height="700"
        MinWidth="680" MinHeight="560"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        Loaded="OnLoaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Height="56"
                     Padding="20,0"
                     Title="DriverUpdater - Settings"
                     Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                     ButtonsForeground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                     ButtonsBackground="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                     ShowMinimize="True"
                     ShowMaximize="False"
                     CanMaximize="False"
                     ShowClose="True" />

        <Grid Grid.Row="1">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl x:Name="SettingsTabs" Grid.Row="0" Margin="16">
            <TabItem Header="Sources">
                <StackPanel Margin="16">
                    <Button Margin="0,0,0,12"
                            Padding="14,7"
                            HorizontalAlignment="Left"
                            Content="{DynamicResource Settings.OpenGuide}"
                            Click="OnOpenWelcomeGuide" />
                    <CheckBox Margin="0,0,0,12"
                              IsChecked="{Binding ShowGuideOnStartup}"
                              Content="{DynamicResource Settings.ShowGuideOnStartup}" />
                    <CheckBox IsChecked="{Binding EnableWindowsUpdate}"
                              Content="Windows Update (recommended)"
                              IsEnabled="False" />
                    <TextBlock Margin="22,2,0,12"
                               Opacity="0.7"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Text="Always on. Provides safe, signed driver updates from Microsoft." />

                    <CheckBox IsChecked="{Binding EnableMicrosoftCatalog}"
                              Content="Microsoft Update Catalog (opt-in)" />
                    <TextBlock Margin="22,2,0,12"
                               Opacity="0.7"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Text="Queries catalog.update.microsoft.com per hardware ID. Wider coverage than Windows Update alone. Use at your own discretion." />

                    <CheckBox IsChecked="{Binding EnableOemHints}"
                              Content="OEM tool hints" />
                    <TextBlock Margin="22,2,0,12"
                               Opacity="0.7"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Text="Shows a banner pointing to the manufacturer tool (Lenovo Vantage, Dell Command Update, ...) when one is detected." />

                    <Separator Margin="0,8,0,14" />
                    <TextBlock FontWeight="SemiBold"
                               Text="Driver update cache" />
                    <TextBlock Margin="0,6,0,10"
                               Opacity="0.7"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Text="Every scan checks all drivers again. When no new result is found, the previous cached result is shown as a fallback. Clear the cache to remove all saved driver rows and update results so the next scan starts from scratch." />
                    <Button Padding="14,7"
                            HorizontalAlignment="Left"
                            Content="Clear cached driver results"
                            Command="{Binding ClearDriverCacheCommand}" />
                </StackPanel>
            </TabItem>

            <TabItem Header="Safety">
                <StackPanel Margin="16">
                    <CheckBox IsChecked="{Binding CreateRestorePoint}"
                              Content="Create a System Restore point before any update batch" />
                    <CheckBox Margin="0,8,0,0"
                              IsChecked="{Binding BackupBeforeInstall}"
                              Content="Back up the current driver before installing a new one" />
                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                        <TextBlock VerticalAlignment="Center" Text="Keep backups for" />
                        <TextBox Width="60"
                                 Margin="8,0,8,0"
                                 Text="{Binding BackupRetentionDays}" />
                        <TextBlock VerticalAlignment="Center" Text="days" />
                    </StackPanel>
                    <Separator Margin="0,16,0,8" />
                    <TextBlock FontWeight="SemiBold" Text="Advanced scraping" />
                    <CheckBox Margin="0,8,0,0"
                              IsChecked="{Binding EnablePlaywrightFallback}"
                              Content="Use headless browser as fallback when motherboard vendor API is blocked (~250 MB Chromium download on first use)" />
                    <TextBlock Margin="22,4,0,0"
                               Opacity="0.7"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Text="When Gigabyte/ASUS/MSI/etc. block the lightweight API call (Akamai 403), the app boots a headless Chromium and reads the rendered DOM. First run downloads ~250 MB of browser binaries; subsequent runs reuse them." />
                </StackPanel>
            </TabItem>

            <TabItem Header="Application">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16">
                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Text="Close button" />
                        <TextBlock Margin="0,6,0,12"
                                   Opacity="0.7"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Text="Choose exactly what happens when you click the X button in the main window." />
                        <ComboBox Width="360"
                                  HorizontalAlignment="Left"
                                  SelectedValuePath="Tag"
                                  SelectedValue="{Binding CloseBehavior, Mode=TwoWay}">
                            <ComboBoxItem Content="Exit DriverUpdater completely"
                                          Tag="{x:Static models:WindowCloseBehavior.ExitApplication}" />
                            <ComboBoxItem Content="Hide the window and keep running"
                                          Tag="{x:Static models:WindowCloseBehavior.KeepRunningInBackground}" />
                        </ComboBox>
                        <TextBlock Margin="0,8,0,0"
                                   Opacity="0.7"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Text="Default: exit completely. If background mode is selected, use the DriverUpdater icon in the Windows notification area to reopen or exit the app." />

                        <Separator Margin="0,22,0,18" />

                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Text="Start with Windows" />
                        <CheckBox Margin="0,12,0,0"
                                  IsChecked="{Binding StartWithWindows}"
                                  Content="Start DriverUpdater when I sign in to Windows" />
                        <TextBlock Margin="22,5,0,0"
                                   Opacity="0.7"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Text="Windows will launch DriverUpdater automatically for your user account." />

                        <CheckBox Margin="0,16,0,0"
                                  IsEnabled="{Binding CanStartMinimized}"
                                  IsChecked="{Binding StartMinimized}"
                                  Content="Start in the notification area without opening the window" />
                        <TextBlock Margin="22,5,0,0"
                                   Opacity="0.7"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Text="Available when both Start with Windows and background mode are enabled. Open the app from its notification area icon whenever you need it." />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Schedule">
                <StackPanel Margin="16">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Width="120" VerticalAlignment="Center" Text="Mode" />
                        <ComboBox Width="220"
                                  ItemsSource="{Binding AvailableModes}"
                                  SelectedItem="{Binding ScheduleMode}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Width="120" VerticalAlignment="Center" Text="Cadence" />
                        <ComboBox Width="220"
                                  ItemsSource="{Binding AvailableCadences}"
                                  SelectedItem="{Binding ScheduleCadence}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Width="120" VerticalAlignment="Center" Text="Day of week" />
                        <ComboBox Width="220"
                                  ItemsSource="{Binding AvailableDays}"
                                  SelectedItem="{Binding ScheduleDayOfWeek}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Width="120" VerticalAlignment="Center" Text="Time" />
                        <TextBox Width="120"
                                 Text="{Binding ScheduleTimeOfDay, StringFormat=HH:mm}" />
                    </StackPanel>

                    <Border Padding="14,10"
                            CornerRadius="6"
                            Margin="0,12,0,0"
                            Background="#FFFFF4E5"
                            Visibility="{Binding ShowAutoUpdateWarning, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold"
                                       Foreground="#FF8B5A00"
                                       Text="Caution: automatic updates run unattended" />
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="#FF8B5A00"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Text="The scheduled task will install drivers without your interaction. A bad GPU or storage driver may prevent the machine from booting. Restore point + backup mitigate but do not eliminate this risk." />
                            <CheckBox Margin="0,8,0,0"
                                      IsChecked="{Binding AcceptedAutoUpdateRisk}"
                                      Content="I understand and want to enable automatic updates" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </TabItem>

            <TabItem Header="Logs">
                <StackPanel Margin="16">
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="Automatic log cleanup" />
                    <TextBlock Margin="0,6,0,16"
                               Opacity="0.7"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Text="DriverUpdater can remove old log files automatically so they do not accumulate over time." />

                    <CheckBox IsChecked="{Binding EnableAutomaticLogCleanup}"
                              Content="Automatically delete old log files" />

                    <StackPanel Margin="22,14,0,0"
                                IsEnabled="{Binding EnableAutomaticLogCleanup}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock VerticalAlignment="Center" Text="Keep logs for" />
                            <TextBox Width="60"
                                     Margin="8,0"
                                     Text="{Binding LogRetentionDays}" />
                            <TextBlock VerticalAlignment="Center" Text="days" />
                        </StackPanel>
                        <TextBlock Margin="0,6,0,0"
                                   Opacity="0.7"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Text="Default: 7 days. You can choose between 1 and 365 days. Cleanup runs when the app starts, after saving these settings, and once a day while the app is open." />
                    </StackPanel>

                    <Separator Margin="0,20,0,14" />
                    <TextBlock FontWeight="SemiBold" Text="Log folder" />
                    <TextBlock Margin="0,6,0,0"
                               Opacity="0.75"
                               FontSize="12"
                               Text="{Binding LogDirectoryPath}"
                               TextWrapping="Wrap" />
                    <TextBlock Margin="0,8,0,0"
                               Opacity="0.7"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Text="Only DriverUpdater log files older than the selected age are removed. The folder itself and unrelated files are never deleted. Turn this option off to keep all log files." />
                </StackPanel>
            </TabItem>

            <TabItem Header="{DynamicResource Settings.Tab.Language}">
                <StackPanel Margin="16">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Width="120"
                                   VerticalAlignment="Center"
                                   Text="{DynamicResource Settings.Language.Label}" />
                        <ComboBox Width="220"
                                  ItemsSource="{Binding AvailableLanguages}"
                                  SelectedItem="{Binding SelectedLanguage}" />
                    </StackPanel>
                    <TextBlock Opacity="0.7"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Text="{DynamicResource Settings.Language.Hint}" />
                </StackPanel>
            </TabItem>

            <TabItem Header="{DynamicResource Settings.Tab.Ai}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16">
                        <TextBlock TextWrapping="Wrap"
                                   Opacity="0.8"
                                   FontSize="12"
                                   Margin="0,0,0,12"
                                   Text="{DynamicResource Settings.Ai.Intro}" />

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Width="120"
                                       VerticalAlignment="Center"
                                       Text="{DynamicResource Settings.Ai.Provider}" />
                            <ComboBox Width="240"
                                      ItemsSource="{Binding AvailableAiProviders}"
                                      SelectedItem="{Binding SelectedAiProvider}" />
                        </StackPanel>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="240" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Text="{DynamicResource Settings.Ai.ResponseLanguage}" />
                            <ComboBox Grid.Column="1"
                                      SelectedValuePath="Tag"
                                      SelectedValue="{Binding SelectedAiResponseLanguage}">
                                <ComboBoxItem Content="{DynamicResource Settings.Ai.ResponseLanguage.English}"
                                              Tag="{x:Static models:AppLanguage.English}" />
                                <ComboBoxItem Content="{DynamicResource Settings.Ai.ResponseLanguage.Hebrew}"
                                              Tag="{x:Static models:AppLanguage.Hebrew}" />
                            </ComboBox>
                        </Grid>
                        <TextBlock Margin="120,0,0,12"
                                   Opacity="0.7"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Text="{DynamicResource Settings.Ai.ResponseLanguageHint}" />

                        <Border Padding="14,12"
                                CornerRadius="6"
                                Margin="0,8,0,0"
                                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                                Visibility="{Binding IsGeminiSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock FontSize="16" FontWeight="SemiBold" Text="Google Gemini" />
                                        <TextBlock Margin="0,3,0,0"
                                                   Opacity="0.7"
                                                   FontSize="12"
                                                   Text="Use Gemini to verify driver updates after each scan." />
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Margin="16,0,0,0"
                                            Padding="12,6"
                                            VerticalAlignment="Top"
                                            Style="{DynamicResource AccentButtonStyle}"
                                            Content="{DynamicResource Settings.Ai.OpenApiKeys}"
                                            Click="OnOpenGeminiApiKeys" />
                                </Grid>

                                <Separator Margin="0,14,0,12" />
                                <TextBlock Text="{DynamicResource Settings.Ai.ApiKeys}"
                                           FontWeight="SemiBold" />
                                <TextBlock Margin="0,3,0,8"
                                           Opacity="0.7"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Text="Add one or more keys. DriverUpdater moves to the next key when a quota is reached." />
                                <ItemsControl ItemsSource="{Binding GeminiApiKeys}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <PasswordBox Grid.Column="0"
                                                             MinWidth="260"
                                                             Loaded="OnGeminiKeyBoxLoaded"
                                                             PasswordChanged="OnGeminiKeyChanged" />
                                                <Button Grid.Column="1"
                                                        Margin="8,0,0,0"
                                                        Padding="12,6"
                                                        Content="{DynamicResource Settings.Ai.RemoveKey}"
                                                        Command="{Binding DataContext.RemoveGeminiApiKeyCommand, RelativeSource={RelativeSource AncestorType={x:Type ui:FluentWindow}}}"
                                                        CommandParameter="{Binding}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Button Margin="0,2,0,0"
                                        Padding="12,6"
                                        HorizontalAlignment="Left"
                                        Content="{DynamicResource Settings.Ai.AddKey}"
                                        Command="{Binding AddGeminiApiKeyCommand}" />
                                <Border Margin="0,10,0,0"
                                        Padding="12,10"
                                        CornerRadius="6"
                                        Background="#FFFFF4E5">
                                    <TextBlock TextWrapping="Wrap"
                                               Foreground="#FF8B5A00"
                                               FontSize="12"
                                               Text="{DynamicResource Settings.Ai.FallbackExplanation}" />
                                </Border>
                                <Separator Margin="0,14,0,12" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               VerticalAlignment="Center"
                                               Text="{DynamicResource Settings.Ai.Model}" />
                                    <TextBox Grid.Column="1"
                                             MinWidth="220"
                                             Text="{Binding GeminiModel}" />
                                </Grid>
                                <CheckBox Margin="0,12,0,0"
                                          IsChecked="{Binding EnableAiWebSearch}"
                                          Content="{DynamicResource Settings.Ai.WebSearch}" />

                                <Expander Margin="0,12,0,0"
                                          Header="{DynamicResource Settings.Ai.GeminiGuideHeader}">
                                    <StackPanel Margin="0,8,0,0">
                                        <TextBlock TextWrapping="Wrap"
                                                   FontSize="12"
                                                   Opacity="0.9"
                                                   Text="{DynamicResource Settings.Ai.GeminiGuideBody}" />
                                        <TextBlock Margin="0,8,0,0" FontSize="12">
                                            <Hyperlink NavigateUri="https://aistudio.google.com/api-keys"
                                                       RequestNavigate="OnHyperlinkRequestNavigate">
                                                <Run Text="https://aistudio.google.com/api-keys" />
                                            </Hyperlink>
                                        </TextBlock>
                                    </StackPanel>
                                </Expander>
                            </StackPanel>
                        </Border>

                        <Border Padding="14,12"
                                CornerRadius="6"
                                Margin="0,8,0,0"
                                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                                Visibility="{Binding IsOllamaSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Text="Ollama (local)" />
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <TextBlock Width="120" VerticalAlignment="Center" Text="{DynamicResource Settings.Ai.OllamaUrl}" />
                                    <TextBox Width="320" Text="{Binding OllamaBaseUrl}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <TextBlock Width="120" VerticalAlignment="Center" Text="{DynamicResource Settings.Ai.Model}" />
                                    <TextBox Width="320" Text="{Binding OllamaModel}" />
                                </StackPanel>

                                <Expander Margin="0,12,0,0"
                                          Header="{DynamicResource Settings.Ai.OllamaGuideHeader}">
                                    <StackPanel Margin="0,8,0,0">
                                        <TextBlock TextWrapping="Wrap"
                                                   FontSize="12"
                                                   Opacity="0.9"
                                                   Text="{DynamicResource Settings.Ai.OllamaGuideBody}" />
                                        <TextBlock Margin="0,8,0,0" FontSize="12">
                                            <Hyperlink NavigateUri="https://ollama.com/download"
                                                       RequestNavigate="OnHyperlinkRequestNavigate">
                                                <Run Text="https://ollama.com/download" />
                                            </Hyperlink>
                                        </TextBlock>
                                    </StackPanel>
                                </Expander>
                            </StackPanel>
                        </Border>

                        <Border Padding="14,10"
                                CornerRadius="6"
                                Margin="0,12,0,0"
                                Background="#FFFFF4E5">
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="#FF8B5A00"
                                       FontSize="12"
                                       Text="{DynamicResource Settings.Ai.KeyWarning}" />
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="About">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="16">
                    <TextBlock Text="{DynamicResource App.Version}" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock Margin="0,8,0,0" Opacity="0.7">
                        <Run Text="Settings file: " /><Run Text="{Binding SettingsPath, Mode=OneWay}" />
                    </TextBlock>

                    <StackPanel Margin="0,20,0,0"
                                Visibility="{Binding CanCheckForUpdates, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <Button Padding="14,6"
                                    Content="Check for updates"
                                    Command="{Binding CheckForUpdatesCommand}" />
                            <ProgressBar Width="120"
                                         Height="4"
                                         Margin="12,0,0,0"
                                         VerticalAlignment="Center"
                                         IsIndeterminate="True"
                                         Visibility="{Binding IsCheckingForUpdates, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </StackPanel>
                        <TextBlock Margin="0,8,0,0"
                                   Opacity="0.7"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Text="Checks GitHub for a newer version. If one is found you'll be asked to install it - the app downloads it and restarts, no need to close and reopen." />

                        <CheckBox Margin="0,16,0,0"
                                  Content="Automatically check for updates on startup"
                                  IsChecked="{Binding CheckForUpdatesOnStartup, Mode=TwoWay}" />
                        <CheckBox Margin="0,8,0,0"
                                  Content="Install updates automatically (no prompt)"
                                  IsEnabled="{Binding CheckForUpdatesOnStartup}"
                                  IsChecked="{Binding AutoInstallAppUpdates, Mode=TwoWay}" />
                        <TextBlock Margin="0,6,0,0"
                                   Opacity="0.7"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Text="With automatic install on, a found update is downloaded and applied on startup and the app restarts onto the new version." />
                    </StackPanel>

                    <Border Margin="0,22,0,0"
                            Padding="14,12"
                            CornerRadius="6"
                            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold"
                                       Text="Windows startup and background mode" />
                            <TextBlock Margin="0,6,0,0"
                                       Opacity="0.75"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Text="In the Application tab you can choose whether X exits DriverUpdater or keeps it running in the Windows notification area. You can also start it automatically with Windows and, if background mode is enabled, start it without opening the main window." />
                        </StackPanel>
                    </Border>
                </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <Border Grid.Row="1"
                Padding="16,10"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           VerticalAlignment="Center"
                           Opacity="0.85"
                           FontSize="12"
                           Text="{Binding StatusText}" />
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button MinWidth="100"
                            Content="Close"
                            IsCancel="True"
                            Click="OnClose" />
                    <Button MinWidth="100"
                            Margin="8,0,0,0"
                            Style="{DynamicResource AccentButtonStyle}"
                            Content="Save"
                            Command="{Binding SaveCommand}" />
                </StackPanel>
            </Grid>
        </Border>
        </Grid>
    </Grid>
</ui:FluentWindow>
