<ui:FluentWindow x:Class="DriverUpdater.App.Views.SupportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:DriverUpdater.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:SupportViewModel}"
        Title="DriverUpdater - Support"
        Icon="pack://application:,,,/Assets/app.ico"
        Width="540" Height="560"
        MinWidth="500" MinHeight="520"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Height="56"
                     Padding="20,0"
                     Title="DriverUpdater - Support"
                     Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                     ButtonsForeground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                     ButtonsBackground="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                     ShowMinimize="True"
                     ShowMaximize="False"
                     CanMaximize="False"
                     ShowClose="True" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20">
                <Border Height="142" CornerRadius="16">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FFFFF3E6" Offset="0" />
                            <GradientStop Color="#FFFFD8A8" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="132" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Viewbox Grid.Column="0" Width="86" Height="86">
                            <Canvas Width="64" Height="64">
                                <Path Data="M14,25 H45 V40 C45,48 39,53 30,53 H27 C19,53 14,48 14,40 Z"
                                      Fill="#FFFFFFFF" />
                                <Path Data="M45,29 H50 C57,29 59,34 57,39 C56,43 52,45 46,45"
                                      Fill="Transparent"
                                      Stroke="#FFFFFFFF"
                                      StrokeThickness="5"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" />
                                <Path Data="M10,55 H51"
                                      Stroke="#FFB45309"
                                      StrokeThickness="4"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" />
                                <Path Data="M22,20 C16,15 27,12 22,6"
                                      Fill="Transparent"
                                      Stroke="#FFB45309"
                                      StrokeThickness="3"
                                      StrokeStartLineCap="Round" />
                                <Path Data="M34,20 C28,15 39,12 34,6"
                                      Fill="Transparent"
                                      Stroke="#FFB45309"
                                      StrokeThickness="3"
                                      StrokeStartLineCap="Round" />
                            </Canvas>
                        </Viewbox>

                        <StackPanel Grid.Column="1"
                                    Margin="0,0,22,0"
                                    VerticalAlignment="Center">
                            <TextBlock FontSize="22"
                                       FontWeight="SemiBold"
                                       Foreground="#FF6F3600"
                                       Text="Fuel the next update" />
                            <TextBlock Margin="0,7,0,0"
                                       Foreground="#FF7A4515"
                                       TextWrapping="Wrap"
                                       Text="If DriverUpdater saved you time, you can help keep the coffee warm and future updates coming." />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Margin="0,18,0,0"
                        Padding="18"
                        CornerRadius="10"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,16,0">
                            <TextBlock FontSize="17"
                                       FontWeight="SemiBold"
                                       Text="Buy me a coffee" />
                            <TextBlock Margin="0,5,0,0"
                                       Opacity="0.72"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Text="Support development through GitHub Sponsors. Every contribution is optional and appreciated." />
                        </StackPanel>
                        <Button Grid.Column="1"
                                MinWidth="156"
                                Padding="14,8"
                                VerticalAlignment="Center"
                                Background="#FFB45309"
                                Foreground="White"
                                BorderBrush="#FF8A3F00"
                                Content="Buy me a coffee"
                                Command="{Binding OpenSponsorsCommand}" />
                    </Grid>
                </Border>

                <Border Margin="0,12,0,0"
                        Padding="18"
                        CornerRadius="10"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,16,0">
                            <TextBlock FontSize="17"
                                       FontWeight="SemiBold"
                                       Text="Leave feedback" />
                            <TextBlock Margin="0,5,0,0"
                                       Opacity="0.72"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Text="Found a problem or have an idea? Open a pre-filled GitHub issue and tell me about it." />
                        </StackPanel>
                        <Button Grid.Column="1"
                                MinWidth="156"
                                Padding="14,8"
                                VerticalAlignment="Center"
                                Content="Leave feedback"
                                Command="{Binding LeaveFeedbackCommand}" />
                    </Grid>
                </Border>

                <TextBlock Margin="0,16,0,0"
                           HorizontalAlignment="Center"
                           Opacity="0.62"
                           FontSize="11"
                           Text="Support never unlocks features. DriverUpdater stays available to everyone." />
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2"
                Padding="18,10"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center"
                           Opacity="0.75"
                           FontSize="12"
                           Text="{Binding StatusText}"
                           TextWrapping="Wrap" />
                <Button Grid.Column="1"
                        MinWidth="96"
                        Padding="14,5"
                        Content="Close"
                        IsCancel="True"
                        Click="OnClose" />
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
