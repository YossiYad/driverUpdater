<ui:FluentWindow x:Class="DriverUpdater.App.Views.UpdateSummaryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:DriverUpdater.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:UpdateSummaryViewModel}"
        Title="{Binding WindowTitle}"
        Icon="pack://application:,,,/Assets/app.ico"
        Width="780"
        Height="700"
        MinWidth="660"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Height="56"
                     Padding="20,0"
                     Title="{Binding WindowTitle}"
                     Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                     ButtonsForeground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                     ButtonsBackground="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                     ShowMinimize="True"
                     ShowMaximize="False"
                     CanMaximize="False"
                     ShowClose="True" />

        <Grid Grid.Row="1">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="24,18"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
            <StackPanel>
                <TextBlock Text="{Binding Header}"
                           FontSize="22"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap" />
                <TextBlock Margin="0,5,0,0"
                           Text="{Binding Subheader}"
                           FontSize="13"
                           Opacity="0.72"
                           TextWrapping="Wrap" />
                <WrapPanel Margin="0,14,0,0">
                    <Border Padding="10,5"
                            Margin="0,0,8,0"
                            CornerRadius="12"
                            Background="#332E7D32">
                        <TextBlock Text="{Binding VerifiedCountText}"
                                   Foreground="#FF7FD18A"
                                   FontWeight="SemiBold" />
                    </Border>
                    <Border Padding="10,5"
                            Margin="0,0,8,0"
                            CornerRadius="12"
                            Background="#339A6700">
                        <TextBlock Text="{Binding PendingCountText}"
                                   Foreground="#FFFFC768"
                                   FontWeight="SemiBold" />
                    </Border>
                    <Border Padding="10,5"
                            Margin="0,0,8,0"
                            CornerRadius="12"
                            Background="#33B42318">
                        <TextBlock Text="{Binding AttentionCountText}"
                                   Foreground="#FFFF8A80"
                                   FontWeight="SemiBold" />
                    </Border>
                    <Border Padding="10,5"
                            CornerRadius="12"
                            Background="#332563EB">
                        <TextBlock Text="{Binding ManualActionCountText}"
                                   Foreground="#FF93C5FD"
                                   FontWeight="SemiBold" />
                    </Border>
                </WrapPanel>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1"
                      Padding="24,18"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <TextBlock Text="{Binding AiLabel}"
                           FontSize="15"
                           FontWeight="SemiBold" />
                <Border Margin="0,8,0,20"
                        Padding="14"
                        CornerRadius="7"
                        BorderBrush="#FF6D28D9"
                        BorderThickness="1"
                        Background="#226D28D9">
                    <TextBlock Text="{Binding SummaryText}"
                               FontSize="14"
                               LineHeight="21"
                               TextWrapping="Wrap" />
                </Border>

                <TextBlock Text="{Binding ResultsHeader}"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8" />

                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:UpdateSummaryItemViewModel}">
                            <Border Margin="0,0,0,10"
                                    Padding="14"
                                    CornerRadius="7"
                                    BorderBrush="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                                    BorderThickness="1"
                                    Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="42" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0"
                                            Width="32"
                                            Height="32"
                                            VerticalAlignment="Top"
                                            CornerRadius="16"
                                            Background="{Binding StatusColor}">
                                        <TextBlock Text="{Binding StatusIcon}"
                                                   Foreground="White"
                                                   FontSize="17"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel Grid.Column="1">
                                        <DockPanel LastChildFill="True">
                                            <TextBlock DockPanel.Dock="Right"
                                                       Margin="12,0,0,0"
                                                       Text="{Binding StatusText}"
                                                       Foreground="{Binding StatusColor}"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding DeviceName}"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />
                                        </DockPanel>
                                        <TextBlock Margin="0,2,0,0"
                                                   Text="{Binding CategoryText}"
                                                   FontSize="12"
                                                   Opacity="0.65" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Text="{Binding Explanation}"
                                                   FontSize="13"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Text="{Binding VersionText}"
                                                   FontSize="12"
                                                   Opacity="0.65"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2"
                Padding="24,12"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button MinWidth="120"
                        Padding="14,6"
                        Content="{Binding CopyButtonText}"
                        Click="OnCopy" />
                <Button MinWidth="100"
                        Margin="8,0,0,0"
                        Padding="14,6"
                        Content="{Binding CloseButtonText}"
                        IsDefault="True"
                        IsCancel="True"
                        Style="{DynamicResource AccentButtonStyle}"
                        Click="OnClose" />
            </StackPanel>
        </Border>
        </Grid>
    </Grid>
</ui:FluentWindow>
