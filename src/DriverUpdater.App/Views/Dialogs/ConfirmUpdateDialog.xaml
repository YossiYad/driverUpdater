<ui:FluentWindow x:Class="DriverUpdater.App.Views.Dialogs.ConfirmUpdateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:DriverUpdater.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:ConfirmUpdateDialogViewModel}"
        Title="{DynamicResource Confirm.Title}"
        Icon="pack://application:,,,/Assets/app.ico"
        Width="640"
        Height="660"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        >

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Height="56"
                     Padding="20,0"
                     Title="{DynamicResource Confirm.Title}"
                     Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                     ButtonsForeground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                     ButtonsBackground="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                     ShowMinimize="True"
                     ShowMaximize="False"
                     CanMaximize="False"
                     ShowClose="True" />

        <Grid Grid.Row="1" Margin="24,16,24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{DynamicResource Confirm.Title}"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Margin="0,0,0,4" />

        <TextBlock Grid.Row="1"
                   Text="{Binding Operation.TargetSnapshot.DeviceName}"
                   FontSize="14"
                   Opacity="0.7"
                   Margin="0,0,0,16" />

        <Border Grid.Row="2"
                Padding="14,10"
                CornerRadius="6"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="{DynamicResource Confirm.Current}" FontWeight="SemiBold" Opacity="0.8" />
                    <TextBlock Margin="0,4,0,0" Text="{Binding Operation.TargetSnapshot.CurrentVersion, FallbackValue=Unknown}" />
                    <TextBlock Opacity="0.6" FontSize="12" Text="{Binding Operation.TargetSnapshot.CurrentDate, FallbackValue=Unknown}" />
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="{DynamicResource Confirm.Available}" FontWeight="SemiBold" Opacity="0.8" />
                    <TextBlock Margin="0,4,0,0" Text="{Binding Operation.Candidate.NewVersion}" />
                    <TextBlock Opacity="0.6" FontSize="12" Text="{Binding Operation.Candidate.NewDate}" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="3"
                Margin="0,12,0,0"
                Padding="14,10"
                CornerRadius="6"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
            <StackPanel>
                <TextBlock Text="{DynamicResource Confirm.Source}" FontWeight="SemiBold" Opacity="0.8" />
                <TextBlock Margin="0,4,0,0" Text="{Binding Operation.Candidate.Source}" />
                <TextBlock Opacity="0.6" FontSize="12" Text="{Binding InstallKindText}" />
                <TextBlock Opacity="0.6" FontSize="12" Text="{Binding SizeText}" />
                <TextBlock Opacity="0.6" FontSize="12" Text="{Binding Operation.Candidate.DownloadUrl}" />
            </StackPanel>
        </Border>

        <Border Grid.Row="4"
                Margin="0,12,0,0"
                Padding="14,10"
                CornerRadius="6"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
            <StackPanel>
                <CheckBox Content="{DynamicResource Confirm.CreateRestorePoint}"
                          IsChecked="{Binding CreateRestorePoint}" />
                <CheckBox Margin="0,4,0,0"
                          Content="{DynamicResource Confirm.BackupDriver}"
                          IsChecked="{Binding BackupCurrentDriver}" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="5"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
            <Border Margin="0,12,0,0"
                    Padding="14,10"
                    CornerRadius="6"
                    Background="#FFFFE8CC"
                    Visibility="{Binding ShowInstallImpactWarning, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Confirm.ImpactHeader}"
                               FontWeight="SemiBold"
                               FontSize="13"
                               Foreground="#FF8B4A00" />
                    <TextBlock Margin="0,5,0,0"
                               Text="{DynamicResource Confirm.RestartRequired}"
                               TextWrapping="Wrap"
                               FontWeight="SemiBold"
                               FontSize="12"
                               Foreground="#FF8B4A00"
                               Visibility="{Binding ShowRestartRequiredWarning, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <TextBlock Margin="0,5,0,0"
                               Text="{DynamicResource Confirm.RestartPossible}"
                               TextWrapping="Wrap"
                               FontSize="12"
                               Foreground="#FF8B4A00"
                               Visibility="{Binding ShowRestartPossibleWarning, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <TextBlock Margin="0,5,0,0"
                               Text="{DynamicResource Confirm.Impact.Display}"
                               TextWrapping="Wrap"
                               FontSize="12"
                               Foreground="#FF8B4A00"
                               Visibility="{Binding ShowDisplayImpact, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <TextBlock Margin="0,5,0,0"
                               Text="{DynamicResource Confirm.Impact.Network}"
                               TextWrapping="Wrap"
                               FontSize="12"
                               Foreground="#FF8B4A00"
                               Visibility="{Binding ShowNetworkImpact, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <TextBlock Margin="0,5,0,0"
                               Text="{DynamicResource Confirm.Impact.AudioCamera}"
                               TextWrapping="Wrap"
                               FontSize="12"
                               Foreground="#FF8B4A00"
                               Visibility="{Binding ShowAudioCameraImpact, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <TextBlock Margin="0,5,0,0"
                               Text="{DynamicResource Confirm.Impact.Input}"
                               TextWrapping="Wrap"
                               FontSize="12"
                               Foreground="#FF8B4A00"
                               Visibility="{Binding ShowInputDeviceImpact, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <TextBlock Margin="0,5,0,0"
                               Text="{DynamicResource Confirm.Impact.StorageSystem}"
                               TextWrapping="Wrap"
                               FontSize="12"
                               Foreground="#FF8B4A00"
                               Visibility="{Binding ShowStorageSystemImpact, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <TextBlock Margin="0,5,0,0"
                               Text="{DynamicResource Confirm.Impact.Printer}"
                               TextWrapping="Wrap"
                               FontSize="12"
                               Foreground="#FF8B4A00"
                               Visibility="{Binding ShowPrinterImpact, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <TextBlock Margin="0,5,0,0"
                               Text="{DynamicResource Confirm.Impact.Generic}"
                               TextWrapping="Wrap"
                               FontSize="12"
                               Foreground="#FF8B4A00"
                               Visibility="{Binding ShowGenericDeviceImpact, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <TextBlock Margin="0,5,0,0"
                               Text="{DynamicResource Confirm.Impact.VendorInstaller}"
                               TextWrapping="Wrap"
                               FontSize="12"
                               Foreground="#FF8B4A00"
                               Visibility="{Binding ShowVendorInstallerImpact, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </StackPanel>
            </Border>

            <Border Margin="0,12,0,0"
                    Padding="14,10"
                    CornerRadius="6"
                    Background="{Binding AiBackground}"
                    Visibility="{Binding HasAiVerdict, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="{Binding AiHeader}"
                               FontWeight="SemiBold"
                               FontSize="13"
                               Foreground="{Binding AiForeground}" />
                    <TextBlock Margin="0,4,0,0"
                               TextWrapping="Wrap"
                               FontSize="12"
                               Foreground="{Binding AiForeground}"
                               Text="{Binding AiSummary}" />
                    <TextBlock Margin="0,6,0,0"
                               TextWrapping="Wrap"
                               FontSize="12"
                               Opacity="0.85"
                               Foreground="{Binding AiForeground}"
                               Text="{Binding AiRationale}" />
                    <TextBlock Margin="0,6,0,0"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{Binding AiForeground}"
                               Text="{Binding AiLatestVersionText}"
                               Visibility="{Binding HasAiLatestVersion, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </StackPanel>
            </Border>

            <Border Margin="0,12,0,0"
                    Padding="14,10"
                    CornerRadius="6"
                    Background="#FFFFF4E5"
                    Visibility="{Binding ShowRiskWarning, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock TextWrapping="Wrap"
                           Foreground="#FF8B5A00"
                           FontSize="12">
                    <Run FontWeight="SemiBold" Text="{DynamicResource Confirm.RiskHeader}" />
                    <Run Text=" " />
                    <Run Text="{DynamicResource Confirm.RiskBody}" />
                </TextBlock>
            </Border>
        </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="6"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button MinWidth="100"
                    Content="{DynamicResource Confirm.CancelButton}"
                    IsCancel="True"
                    Click="OnCancel" />
            <Button MinWidth="100"
                    Margin="8,0,0,0"
                    Content="{DynamicResource Confirm.ProceedButton}"
                    IsDefault="True"
                    Style="{DynamicResource AccentButtonStyle}"
                    Click="OnProceed" />
        </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
