<ui:FluentWindow x:Class="DriverUpdater.App.Views.Dialogs.AiScanWarningDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="{DynamicResource AiScanWarning.Title}"
                 Width="540"
                 SizeToContent="Height"
                 MinHeight="360"
                 ResizeMode="NoResize"
                 WindowStartupLocation="CenterOwner">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock FontSize="21"
                       FontWeight="SemiBold"
                       Text="{DynamicResource AiScanWarning.Heading}" />
            <TextBlock x:Name="UsageSummaryText"
                       Margin="0,12,0,0"
                       FontSize="14"
                       TextWrapping="Wrap" />
        </StackPanel>

        <Border Grid.Row="1"
                Margin="0,16,0,0"
                Padding="14,12"
                CornerRadius="6"
                Background="#FFFFF4E5">
            <TextBlock x:Name="QuotaExplanationText"
                       Foreground="#FF8B5A00"
                       TextWrapping="Wrap" />
        </Border>

        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                <TextBlock FontWeight="SemiBold"
                           Text="{DynamicResource AiScanWarning.DailyLimitLabel}" />
                <TextBlock Margin="0,3,0,0"
                           FontSize="12"
                           Opacity="0.72"
                           TextWrapping="Wrap"
                           Text="{DynamicResource AiScanWarning.DailyLimitHint}" />
            </StackPanel>
            <TextBox x:Name="DailyLimitBox"
                     Grid.Column="1"
                     VerticalContentAlignment="Center"
                     PreviewTextInput="OnDailyLimitPreviewTextInput"
                     TextChanged="OnDailyLimitTextChanged" />
            <Button Grid.Column="2"
                    Margin="8,0,0,0"
                    Padding="10,6"
                    Content="{DynamicResource AiScanWarning.OpenLimits}"
                    Click="OnOpenRateLimits" />
        </Grid>

        <CheckBox x:Name="DoNotShowAgainBox"
                  Grid.Row="3"
                  Margin="0,18,0,0"
                  Content="{DynamicResource AiScanWarning.DoNotShowAgain}" />

        <StackPanel Grid.Row="4"
                    Margin="0,24,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal"
                    FlowDirection="LeftToRight">
            <Button MinWidth="96"
                    Padding="14,7"
                    Content="{DynamicResource AiScanWarning.Cancel}"
                    IsCancel="True" />
            <Button Margin="8,0,0,0"
                    MinWidth="124"
                    Padding="14,7"
                    Content="{DynamicResource AiScanWarning.Start}"
                    Style="{DynamicResource AccentButtonStyle}"
                    IsDefault="True"
                    Click="OnStartScan" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
